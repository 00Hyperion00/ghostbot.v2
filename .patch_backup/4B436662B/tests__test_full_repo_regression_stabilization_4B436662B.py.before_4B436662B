def test_phase62b_production_hardening_lock(tmp_path):
    from tradebot.production_hardening import acquire_runtime_lock, release_runtime_lock, build_production_hardening_snapshot
    lock=acquire_runtime_lock(tmp_path/'runtime.lock',identity='pytest')
    try:
        try:
            acquire_runtime_lock(tmp_path/'runtime.lock',identity='pytest'); raised=False
        except RuntimeError as exc: raised='RUNTIME_LOCK_ALREADY_HELD' in str(exc)
        assert raised
    finally: release_runtime_lock(lock)
    assert build_production_hardening_snapshot(object())['ok'] is True
