    async def _market_loop(self) -> None:
        # websocket disconnects are expected; loop keeps trying.
        while self._running:
            try:
                async for msg in self.exchange.stream_market():
                    if not self._running:
                        return
                    data = msg.get('data', {})
                    stream = msg.get('stream', '')
                    now = utc_ms()
                    self.runtime.ws_status = 'CONNECTED'
                    if stream.endswith('@bookTicker'):
                        self._latest_book = {
                            'bestBid': float(data.get('b', 0) or 0),
                            'bestAsk': float(data.get('a', 0) or 0),
                            'lastUpdate': now,
                        }
                    elif '@kline_' in stream:
                        k = data.get('k', {})
                        candle = {
                            'open_time': int(k.get('t', 0)),
                            'close_time': int(k.get('T', 0)),
                            'open': float(k.get('o', 0) or 0),
                            'high': float(k.get('h', 0) or 0),
                            'low': float(k.get('l', 0) or 0),
                            'close': float(k.get('c', 0) or 0),
                            'volume': float(k.get('v', 0) or 0),
                            'quote_volume': float(k.get('q', 0) or 0),
                            'taker_buy_quote_volume': float(k.get('Q', 0) or 0),
                            'closed': bool(k.get('x', False)),
                        }
                        if candle['closed']:
                            from .models import Candle
                            closed = Candle(**candle)
                            if not self._closed_candles or self._closed_candles[-1].close_time != closed.close_time:
                                self._closed_candles.append(closed)
                                self._closed_candles = self._closed_candles[-200:]
                                await self._evaluate_risk_plan_execution(mark=float(closed.close))
                                if self.runtime.pending is None:
                                    await self._evaluate_auto_signal()
                    self._save_runtime()
            except asyncio.CancelledError:
                return
            except Exception as exc:
                self.runtime.ws_status = 'DISCONNECTED'
                self.logger.warn('WS_DISCONNECTED', 'WebSocket bağlantısı kapatıldı', {'reason': 'RECONNECT_PREP', 'error': str(exc)})
                self._save_runtime()
                await asyncio.sleep(2)

    async def _reconcile_loop(self) -> None:
        while True:
            try:
                await asyncio.sleep(1)
                await self._reconcile_pending_order()
            except asyncio.CancelledError:
                return
            except Exception as exc:
                self.logger.error('RECONCILE_LOOP_FAIL', 'Pending reconcile döngüsü hata verdi', {'error': str(exc)})

