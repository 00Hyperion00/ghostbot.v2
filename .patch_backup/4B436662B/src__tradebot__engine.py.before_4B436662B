        return {'present': True, 'qty': position.qty, 'entry_price': position.entry_price, 'source': position.source, 'order_id': position.order_id, 'client_order_id': position.client_order_id, 'opened_at': position.opened_at, 'mark_price': mark, 'unrealized_pnl': unrealized, 'unrealized_pnl_pct': unrealized_pct, 'risk_plan': self._risk_plan_dict(position.risk_plan), 'protective_exit': self._protective_exit_snapshot(position, mark)}

    def _event_audit_snapshot(self) -> dict[str, Any]:
        store = getattr(self, 'store', None)
        if store is None or not hasattr(store, 'fetch_logs'):
            return {'available': False, 'event_count': 0}
        try:
            logs = store.fetch_logs(limit=250, order='asc')
        except Exception:
            return {'available': False, 'event_count': 0}
        counts_by_category: dict[str, int] = {}
        counts_by_severity: dict[str, int] = {}
        for item in logs:
            cat = item.get('category') or item.get('data', {}).get('category') or 'Runtime'
            sev = item.get('severity') or str(item.get('level', 'INFO')).lower()
            counts_by_category[cat] = counts_by_category.get(cat, 0) + 1
            counts_by_severity[sev] = counts_by_severity.get(sev, 0) + 1
        return {'available': True, 'event_count': len(logs), 'counts_by_category': counts_by_category, 'counts_by_severity': counts_by_severity, 'warning_count': counts_by_severity.get('warning', 0), 'error_count': counts_by_severity.get('error', 0)}

    async def _startup_reconcile_persistent_state(self) -> dict[str, Any]:
        now = utc_ms()
        symbol_rules = getattr(self, 'symbol_rules', None)
        settings = getattr(self, 'settings', None)
        snapshot = {'contract_version': '4B.4.3.6.6.12', 'recovered_at': now, 'symbol': getattr(settings, 'symbol', getattr(self.runtime, 'symbol', None)), 'base_asset': symbol_rules.base_asset if symbol_rules else None, 'quote_asset': symbol_rules.quote_asset if symbol_rules else None, 'live_free_base': 0.0, 'base_dust': 0.0, 'tradable_base': 0.0, 'live_position_supported': False, 'open_order_count': 0, 'pending_before': getattr(self.runtime, 'pending', None) is not None, 'position_before': getattr(self.runtime, 'position', None) is not None, 'pending_action': 'UNCHANGED', 'position_action': 'UNCHANGED', 'state_before': str(self.runtime.state), 'warnings': []}
        if symbol_rules:
            base = self.runtime.balances.get(symbol_rules.base_asset, Balance())
            tradable = round_down_to_step(max(base.free - base.dust, 0.0), symbol_rules.step_size)
            snapshot.update({'live_free_base': base.free, 'base_dust': base.dust, 'tradable_base': tradable, 'live_position_supported': tradable >= symbol_rules.min_qty and tradable * (self._latest_mark_price() or 0.0) >= symbol_rules.min_notional * getattr(settings, 'min_notional_buffer_multiplier', 1.0)})
        open_orders = []
        exchange = getattr(self, 'exchange', None)
        if exchange is not None and hasattr(exchange, 'fetch_open_orders'):
            try:
                open_orders = await exchange.fetch_open_orders(getattr(settings, 'symbol', None))
            except Exception as exc:
                snapshot['warnings'].append(f'FETCH_OPEN_ORDERS_FAILED:{exc}')
        snapshot['open_order_count'] = len(open_orders)
        if not hasattr(self.runtime, 'pending'):
            self.runtime.pending = None
        if not hasattr(self.runtime, 'position'):
            self.runtime.position = None
        if open_orders:
            order = open_orders[0]
            side = str(order.get('side') or 'BUY')
            price = float(order.get('price') or order.get('stopPrice') or 0.0)
            orig = float(order.get('origQty') or order.get('quantity') or 0.0)
            executed = float(order.get('executedQty') or 0.0)
            remaining = max(orig - executed, 0.0)
            self.runtime.pending = PendingOrder(side=side, price=price, qty=orig, status=order.get('status', 'NEW'), order_id=str(order.get('orderId')) if order.get('orderId') is not None else None, client_order_id=order.get('clientOrderId'), source='startup_live_open_order_recovery', submitted_at=int(order.get('time') or now), partial_executed_qty=executed, remaining_qty=remaining)
            transition(self.runtime, BotState.BUY_PENDING if side == 'BUY' else BotState.SELL_PENDING)
            snapshot['pending_action'] = 'RECOVERED_LIVE_OPEN_ORDER'
        elif self.runtime.pending is not None:
            self.runtime.pending = None
            snapshot['pending_action'] = 'CLEARED_ORPHAN_LOCAL_PENDING'
        if symbol_rules:
            tradable = float(snapshot['tradable_base'])
            mark = self._latest_mark_price() or 0.0
            live_position_supported = bool(tradable >= symbol_rules.min_qty and tradable * mark >= symbol_rules.min_notional * getattr(settings, 'min_notional_buffer_multiplier', 1.0))
            if self.runtime.position is None and live_position_supported and self.runtime.pending is None:
                self.runtime.position = Position(qty=tradable, entry_price=mark or 0.0, source='startup_live_balance_rehydrate', opened_at=now)
                self._ensure_position_risk_plan()
                transition(self.runtime, BotState.IN_POSITION)
                snapshot['position_action'] = 'REHYDRATED_FROM_LIVE_BALANCE'
            elif self.runtime.position is not None and not live_position_supported and self.runtime.pending is None:
                self.runtime.position = None
                transition(self.runtime, BotState.FLAT)
                snapshot['position_action'] = 'CLEARED_ORPHAN_LOCAL_POSITION'
            elif self.runtime.position is not None and live_position_supported:
                if abs(self.runtime.position.qty - tradable) > 1e-12:
                    self.runtime.position.qty = tradable
                    snapshot['position_action'] = 'SYNCED_QTY_FROM_LIVE_BALANCE'
                transition(self.runtime, BotState.IN_POSITION)
        if self.runtime.pending is None and self.runtime.position is None:
            transition(self.runtime, BotState.FLAT)
        snapshot.update({'state_after': str(self.runtime.state), 'has_pending': self.runtime.pending is not None, 'has_position': self.runtime.position is not None, 'position_source': self.runtime.position.source if self.runtime.position else None, 'pending_source': self.runtime.pending.source if self.runtime.pending else None})
        self.runtime.recovery_snapshot = snapshot
        self.logger.info('RECOVERY_RECONCILE_COMPLETED', 'Restart recovery persistent state mutabakatı tamamlandı', snapshot)
        self._save_runtime()
        return snapshot

    def _latest_mark_price(self) -> float | None:
        latest_book = getattr(self, '_latest_book', None)
        if isinstance(latest_book, dict):
            for key in ('bestBid', 'bestAsk'):
                value = latest_book.get(key)
                if value not in (None, '', 0, 0.0):
                    try:
                        return float(value)
                    except (TypeError, ValueError):
                        continue
        closed_candles = getattr(self, '_closed_candles', None) or []
        if closed_candles:
            try:
                value = getattr(closed_candles[-1], 'close', None)
                if value not in (None, ''):
                    return float(value)
            except (TypeError, ValueError, AttributeError, IndexError):
                return None
        return None

    def _latest_atr(self) -> float | None:
        if len(self._closed_candles) < self.settings.atr_period + 1:
            return None
        from .indicators import atr
        highs = [c.high for c in self._closed_candles]
        lows = [c.low for c in self._closed_candles]
        closes = [c.close for c in self._closed_candles]
        return atr(highs, lows, closes, self.settings.atr_period)[-1]

    async def _evaluate_auto_signal(self) -> None:
        technical = evaluate_technical_strategy(self._closed_candles, self.settings)
        decision = normalize_signal_with_ai(technical, self.settings, closed_candles=self._closed_candles, ai_provider=self.ai_provider)
        self.runtime.last_signal = decision.signal
        self.runtime.signal_reason = decision.reason
        self.runtime.trend = decision.trend
        self.runtime.last_signal_provider = decision.provider
        self.runtime.last_signal_confidence = decision.confidence
        self.runtime.last_signal_metrics = dict(decision.metrics or {})
        self.runtime.last_evaluated_close_time = decision.last_evaluated_close_time
        self._record_model_quality_sample(decision)
        self.runtime.auto_debug = f'NO_ACTION_SIGNAL_HOLD | Sinyal işlem üretmiyor: HOLD' if decision.signal == 'HOLD' else self.runtime.auto_debug
        self.logger.info('STRATEGY_EVAL', 'Strateji değerlendirildi', {'reason': decision.reason, 'signal': decision.signal, 'trend': decision.trend})
        if not self.settings.auto_trade_on_signal:
            self.runtime.auto_debug = 'AUTO_DISABLED | Oto trade kapalı'
            self._record_decision_audit(technical=technical, decision=decision, effective=decision, action='AUTO_DISABLED', should_submit_order=False, skip_code='AUTO_TRADE_DISABLED')
            self._save_runtime()
            return
        effective = effective_auto_signal(decision, self.settings.auto_trade_signal_mode)
        if effective.signal != decision.signal:
            self.logger.info('AUTO_SIGNAL_EFFECTIVE', 'Auto trade için efektif sinyal üretildi', {'effectiveSignal': effective.signal, 'mode': self.settings.auto_trade_signal_mode, 'rawSignal': decision.signal, 'reason': effective.reason})
        signal_key = build_signal_key(self.settings.symbol, self.settings.kline_interval, effective)
        now = utc_ms()
        if effective.signal == 'HOLD':
            self.runtime.auto_debug = 'NO_ACTION_SIGNAL_HOLD | Sinyal işlem üretmiyor: HOLD'
            self._record_decision_audit(technical=technical, decision=decision, effective=effective, signal_key=signal_key, action='AUTO_TRADE_SKIP', should_submit_order=False, skip_code='NO_ACTION_SIGNAL_HOLD')
            self.logger.info('AUTO_TRADE_SKIP', 'Otomatik işlem atlandı', {'hasPending': self.runtime.pending is not None, 'hasPosition': self.runtime.position is not None, 'rawSignal': decision.signal, 'runtimeState': self.runtime.state, 'signal': effective.signal, 'signalKey': signal_key, 'signalMode': self.settings.auto_trade_signal_mode, 'signalReason': effective.reason, 'skipCode': 'NO_ACTION_SIGNAL_HOLD', 'trend': effective.trend})
            self._save_runtime()
            return
        last = self._recent_signal_fps.get(signal_key)
        if last and now - last <= self.settings.auto_trade_cooldown_sec * 1000:
            self._record_decision_audit(technical=technical, decision=decision, effective=effective, signal_key=signal_key, action='AUTO_SIGNAL_DEDUPED', should_submit_order=False, skip_code='SIGNAL_DEDUPED')
            self.logger.info('AUTO_SIGNAL_DEDUPED', 'Aynı sinyal dedupe ile yutuldu', {'signalKey': signal_key, 'signal': effective.signal})
            self._save_runtime()
            return
        self._recent_signal_fps[signal_key] = now
        signal_meta = {
            'hasPending': self.runtime.pending is not None,
            'hasPosition': self.runtime.position is not None,
            'rawSignal': decision.signal,
            'runtimeState': self.runtime.state,
            'signal': effective.signal,
            'signalKey': signal_key,
            'signalMode': self.settings.auto_trade_signal_mode,
            'signalReason': effective.reason,
            'trend': effective.trend,
            'reason': 'AUTO_SIGNAL',
        }
        should_submit = effective.signal in {'BUY', 'SELL'}
        self._record_decision_audit(technical=technical, decision=decision, effective=effective, signal_key=signal_key, action='ORDER_SUBMISSION_PLANNED', should_submit_order=should_submit)
        if effective.signal == 'BUY':
            await self._submit_entry(source='AUTO_SIGNAL', signal_meta=signal_meta)
        elif effective.signal == 'SELL':
            await self._submit_exit(source='AUTO_SIGNAL', signal_meta=signal_meta)
        self._save_runtime()

