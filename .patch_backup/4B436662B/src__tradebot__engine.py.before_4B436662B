                'symbol': getattr(self.settings, 'symbol', getattr(self.runtime, 'symbol', '')),
                'exitPrice': fill_price,
                'qty': fill_qty,
                'pnl': round(float(pnl or 0.0), 6),
                'remainingQty': remaining_qty,
                'source': source,
            }, dedupe_ms=5_000)
            return
        trade = close_trade_record(
            open_trade,
