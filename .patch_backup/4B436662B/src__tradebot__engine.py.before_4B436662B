    async def cancel_pending(self, *, reason: str = 'MANUAL_CANCEL') -> None:
        pending = self.runtime.pending
        if not pending:
            return
        if pending.cancel_requested:
            self.logger.info('ORDER_CANCEL_SUPPRESSED', 'Bekleyen emir için yinelenen iptal talebi bastırıldı', {
                'orderId': pending.order_id,
                'clientOrderId': pending.client_order_id,
                'side': pending.side,
                'reason': reason,
            })
            self._save_runtime()
            return
        if pending.order_id or pending.client_order_id:
            try:
                try:
                    before = await self.exchange.fetch_order(self.settings.symbol, order_id=pending.order_id, client_order_id=pending.client_order_id)
                except Exception:
                    before = None
                if before and before.get('status') == 'FILLED':
                    pending.late_fill_detected = True
                    self._set_reconciliation_snapshot(pending=pending, phase='CANCEL_PRECHECK', action='COMMIT_FILL', order=before, reason='CANCEL_RACE_PRECHECK_FILLED', fill_source='cancel_race_precheck')
                    await self._commit_filled_pending(pending, source='cancel_race_precheck', fill_price=float(before.get('price') or pending.price), fill_qty=float(before.get('executedQty') or pending.qty))
                    self.logger.info('ORDER_CANCEL_RACE_FILLED', 'İptal öncesi emir dolu görüldü; cancel race fill olarak işlendi', {'orderId': pending.order_id, 'side': pending.side})
                    return
                await self.exchange.cancel_order(symbol=self.settings.symbol, order_id=pending.order_id, client_order_id=pending.client_order_id)
            except Exception as exc:
                try:
                    after = await self.exchange.fetch_order(self.settings.symbol, order_id=pending.order_id, client_order_id=pending.client_order_id)
                except Exception:
                    after = None
                if after and after.get('status') == 'FILLED':
                    pending.late_fill_detected = True
                    self._set_reconciliation_snapshot(pending=pending, phase='CANCEL_RACE', action='COMMIT_FILL', order=after, reason='CANCEL_RACE_LATE_FILL', fill_source='cancel_race_fill')
                    await self._commit_filled_pending(pending, source='cancel_race_fill', fill_price=float(after.get('price') or pending.price), fill_qty=float(after.get('executedQty') or pending.qty))
                    self.logger.info('ORDER_CANCEL_RACE_FILLED', 'İptal yarışı sırasında emir dolu görüldü; fill olarak işlendi', {'orderId': pending.order_id, 'side': pending.side})
                    return
                self.logger.warn('ORDER_CANCEL_WARN', 'Canlı emir iptal sorgusu uyarı verdi', {'error': str(exc), 'orderId': pending.order_id})
            self.logger.warn('ORDER_CANCEL_REQUESTED', 'Bekleyen canlı emir için iptal talebi gönderildi', {'orderId': pending.order_id, 'reason': reason, 'side': pending.side})
        pending.cancel_requested = True
        pending.cancel_requested_at = utc_ms()
        pending.status = 'CANCEL_REQUESTED'
        self._set_reconciliation_snapshot(pending=pending, phase='CANCEL_REQUESTED', action='WAIT_CANCEL_CONFIRMATION', reason=reason)
        self._save_runtime()


