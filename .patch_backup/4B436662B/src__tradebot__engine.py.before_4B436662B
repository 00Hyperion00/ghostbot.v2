    async def _evaluate_risk_plan_execution(self, *, mark: float | None = None) -> dict[str, Any]:
        position = self.runtime.position
        if position is None:
            return self._risk_plan_execution_snapshot(None, mark, mutate=False)
        if self.runtime.pending is not None:
            snap = self._risk_plan_execution_snapshot(position, mark, mutate=False)
            snap['blocked_by_pending'] = True
            return snap
        snapshot = self._risk_plan_execution_snapshot(position, mark, mutate=True)
        if not snapshot.get('exit_required'):
            self._save_runtime()
            return snapshot
        reason = str(snapshot.get('exit_reason') or 'RISK_EXIT')
        action = str(snapshot.get('exit_action') or 'FULL_EXIT')
        requested_qty = float(snapshot.get('requested_exit_qty') or 0.0)
        if requested_qty <= 0:
            self.logger.warn('RISK_EXIT_BLOCKED', 'Risk plan çıkış miktarı sıfır olduğu için emir gönderilmedi', {'reason': reason, 'action': action})
            self._save_runtime()
            return snapshot
        self.runtime.active_exit_intent = ExitIntent(kind=reason, source='risk_plan', trigger_price=float(snapshot.get('mark_price') or 0.0), created_at=utc_ms())
        self.logger.warn('RISK_EXIT_TRIGGERED', 'Risk plan koruyucu çıkış tetikledi', {'symbol': self.settings.symbol, 'reason': reason, 'action': action, 'markPrice': snapshot.get('mark_price'), 'requestedQty': requested_qty, 'activeStopLoss': snapshot.get('active_stop_loss'), 'takeProfit': snapshot.get('take_profit')})
        await self._submit_exit(source=f'RISK_{reason}', signal_meta={'reason': reason, 'signal': 'SELL', 'rawSignal': 'RISK_EXIT', 'runtimeState': self.runtime.state, 'riskExitReason': reason, 'riskExitAction': action, 'markPrice': snapshot.get('mark_price')}, requested_qty_override=requested_qty)
        return snapshot

    def _protective_exit_snapshot(self, position: Position | None, mark: float | None) -> dict[str, Any]:
        base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance()) if self.symbol_rules else Balance()
        step = self.symbol_rules.step_size if self.symbol_rules else 1e-8
        min_qty = self.symbol_rules.min_qty if self.symbol_rules else 0.0
        min_notional = (self.symbol_rules.min_notional * self.settings.min_notional_buffer_multiplier) if self.symbol_rules else 0.0
        if position is None:
            return {'present': False, 'protective_exit_ready': False, 'block_reason': 'POSITION_NOT_FOUND', 'tradable_exit_qty': 0.0, 'exit_notional': 0.0, 'is_dust': False}
        requested_qty = round_down_to_step(max(float(position.qty or 0.0), 0.0), step)
        tradable_qty = round_down_to_step(max(float(base.free or 0.0) - float(base.dust or 0.0), 0.0), step)
        exit_qty = round_down_to_step(max(min(requested_qty, tradable_qty) if tradable_qty > 0 else requested_qty, 0.0), step)
        mark_price = float(mark or position.entry_price or 0.0)
        exit_notional = exit_qty * mark_price if mark_price else 0.0
        block_reason = None
        if exit_qty <= 0:
            block_reason = 'EXIT_QTY_ZERO'
        elif exit_qty < min_qty:
            block_reason = 'MIN_QTY_BLOCKED'
        elif min_notional > 0 and exit_notional < min_notional:
            block_reason = 'MIN_NOTIONAL_BLOCKED'
        elif tradable_qty + 1e-12 < requested_qty:
            block_reason = 'LIVE_BASE_BALANCE_BELOW_POSITION_QTY'
        rp = position.risk_plan
        stop_loss = getattr(rp, 'stop_loss', None) if rp else None
        take_profit = getattr(rp, 'take_profit', None) if rp else None
        risk_exec = self._risk_plan_execution_snapshot(position, mark_price, mutate=False) if rp else {'present': False, 'ready': False}
        dist_sl = (mark_price - float(stop_loss)) if mark_price and stop_loss is not None else None
        dist_tp = (float(take_profit) - mark_price) if mark_price and take_profit is not None else None
        unrealized = (mark_price - position.entry_price) * position.qty if mark_price else None
        unrealized_pct = ((mark_price - position.entry_price) / position.entry_price * 100.0) if mark_price and position.entry_price else None
        return {'present': True, 'protective_exit_ready': block_reason is None, 'block_reason': block_reason, 'side': 'SELL', 'requested_qty': requested_qty, 'tradable_exit_qty': exit_qty, 'live_free_base': base.free, 'base_dust': base.dust, 'mark_price': mark_price or None, 'exit_notional': exit_notional, 'min_qty': min_qty, 'min_notional': min_notional, 'is_dust': bool(exit_qty < min_qty or (min_notional > 0 and exit_notional < min_notional)), 'risk_plan_present': rp is not None, 'stop_loss': stop_loss, 'active_stop_loss': risk_exec.get('active_stop_loss'), 'take_profit': take_profit, 'distance_to_stop': dist_sl, 'distance_to_stop_pct': (dist_sl / mark_price * 100.0) if dist_sl is not None and mark_price else None, 'distance_to_take_profit': dist_tp, 'distance_to_take_profit_pct': (dist_tp / mark_price * 100.0) if dist_tp is not None and mark_price else None, 'break_even_trigger_price': getattr(rp, 'break_even_trigger_price', None) if rp else None, 'break_even_stop_price': getattr(rp, 'break_even_stop_price', None) if rp else None, 'break_even_armed': bool(getattr(rp, 'break_even_armed', False)) if rp else False, 'trailing_enabled': bool(getattr(rp, 'trailing_enabled', False)) if rp else False, 'trailing_armed': bool(getattr(rp, 'trailing_armed', False)) if rp else False, 'trailing_stop': getattr(rp, 'trailing_stop', None) if rp else None, 'partial_tp_price': getattr(rp, 'partial_tp_price', None) if rp else None, 'partial_tp_close_pct': getattr(rp, 'partial_tp_close_pct', None) if rp else None, 'partial_tp_triggered': bool(getattr(rp, 'partial_tp_triggered', False)) if rp else False, 'partial_tp_done': bool(getattr(rp, 'partial_tp_triggered', False)) if rp else False, 'last_exit_reason': getattr(rp, 'last_exit_reason', None) if rp else None, 'risk_execution': risk_exec, 'unrealized_pnl': unrealized, 'unrealized_pnl_pct': unrealized_pct}

    def _position_snapshot(self, runtime_payload: dict[str, Any]) -> dict[str, Any]:
        position = self.runtime.position
        mark = self._latest_mark_price()
        if position is None:
            return {'present': False, 'qty': 0.0, 'entry_price': None, 'source': None, 'mark_price': mark, 'unrealized_pnl': None, 'unrealized_pnl_pct': None, 'risk_plan': None, 'protective_exit': self._protective_exit_snapshot(None, mark)}
        self._ensure_position_risk_plan()
