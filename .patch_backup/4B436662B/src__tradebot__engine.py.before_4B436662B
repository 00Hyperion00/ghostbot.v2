class TradeBotEngine:
    def __init__(self, settings: Settings, store: SQLiteStore) -> None:
        self.settings = settings
        self.store = store
        self.logger = EventLogger(store)
        self.exchange = BinanceSpotClient(settings)
        self.runtime = RuntimeState.from_dict(self.store.get_json('runtime', {}))
        self.runtime.symbol = settings.symbol
        self._loop_task: asyncio.Task | None = None
        self._market_task: asyncio.Task | None = None
        self._reconcile_task: asyncio.Task | None = None
        self._recent_signal_fps: dict[str, int] = {}
        self._partial_fill_fingerprints: dict[str, int] = {}
        self._fill_reconcile_fingerprints: dict[str, int] = {}
        self._running = False
        self._closed_candles = []
        self._latest_book: dict[str, Any] = {}
        self.symbol_rules = None
        startup_ai_contract = decision_contract_from_settings(settings)
        self.ai_provider = XGBoostSignalProvider(settings.ai_model_path, **startup_ai_contract.threshold_kwargs()) if settings.ai_provider_enabled and settings.ai_provider_mode == 'local_xgboost' else None
        self.model_quality_monitor = ModelQualityMonitor(config_from_settings(settings))
        self._last_model_quality_event_key = None
        self._save_runtime()

    async def bootstrap(self) -> None:
        self.symbol_rules = await self.exchange.fetch_symbol_rules(self.settings.symbol)
        self.runtime.symbol = self.settings.symbol
        self.logger.info('SYMBOL_RULES_READY', 'Sembol kuralları alındı', {
            'symbol': self.symbol_rules.symbol,
            'baseAsset': self.symbol_rules.base_asset,
            'quoteAsset': self.symbol_rules.quote_asset,
            'stepSize': self.symbol_rules.step_size,
            'tickSize': self.symbol_rules.tick_size,
            'minQty': self.symbol_rules.min_qty,
            'minNotional': self.symbol_rules.min_notional,
        })
        await self.sync_balances(log_code='BALANCES_READY')
        self._closed_candles = await self.exchange.fetch_klines(self.settings.symbol, self.settings.kline_interval, 100)
        if self._closed_candles:
            last = self._closed_candles[-1]
            self.logger.info('BOOTSTRAP_KLINES_OK', 'Geçmiş mum bootstrap tamamlandı', {
                'closedCandles': len(self._closed_candles),
                'requested': 100,
                'signal': 'HOLD',
                'trend': 'UNKNOWN',
            })
        self.runtime.ws_status = 'CONNECTED'
        self._save_runtime()

    def _task_alive(self, task: asyncio.Task | None = None) -> bool:
        return task is not None and not task.done()

    async def _cancel_task(self, task: asyncio.Task | None, *, timeout: float = 0.2) -> None:
        if task is None:
            return
        task.cancel()
        try:
            await asyncio.wait_for(asyncio.gather(task, return_exceptions=True), timeout=timeout)
        except Exception:
            pass

    async def close(self) -> None:
        self._running = False
        await self._cancel_task(self._market_task)
        await self._cancel_task(self._reconcile_task)
        self._market_task = None
        self._reconcile_task = None
        await self.exchange.close()

    def _save_runtime(self) -> None:
        self.store.set_json('runtime', self.runtime.to_dict())

    def _day_key(self) -> str:
        return datetime.now(timezone.utc).strftime('%Y-%m-%d')

    async def sync_balances(self, *, log_code: str = 'BALANCES_READY') -> None:
        balances = await self.exchange.fetch_balances()
        updated: dict[str, Balance] = {}
        for asset, bal in balances.items():
            dust = 0.0
            if self.symbol_rules and asset == self.symbol_rules.base_asset:
                dust = infer_dust(bal.free, self.symbol_rules.step_size)
            updated[asset] = Balance(free=bal.free, locked=bal.locked, dust=dust)
        self.runtime.balances = updated
        if self.symbol_rules:
            base = updated.get(self.symbol_rules.base_asset, Balance())
            self.runtime.dust_snapshot[self.symbol_rules.base_asset] = base.dust
            self.logger.info(log_code, 'Spot bakiyeleri hazırlandı', {
                'baseAsset': self.symbol_rules.base_asset,
                'quoteAsset': self.symbol_rules.quote_asset,
                'liveFetched': True,
                'liveFreeBase': base.free,
                'liveFreeQuote': updated.get(self.symbol_rules.quote_asset, Balance()).free,
                'changed': True,
                'dryRunFreeBase': 0,
                'dryRunFreeQuote': 1000,
            })
        self._save_runtime()

    async def start(self) -> bool:
        if self._running and self._task_alive(self._market_task) and self._task_alive(self._reconcile_task):
            return False
        await self.bootstrap()
        if not hasattr(self.runtime, 'position'):
            self.runtime.position = None
        if not hasattr(self.runtime, 'balances'):
            self.runtime.balances = {}
        symbol_rules = getattr(self, 'symbol_rules', None)
        balances = getattr(self.runtime, 'balances', {}) or {}
        base = balances.get(symbol_rules.base_asset, Balance()) if symbol_rules else Balance()
        recovered_position = getattr(self.runtime, 'position', None)
        tradable_base = round_down_to_step(max(base.free - base.dust, 0.0), symbol_rules.step_size) if symbol_rules else base.free
        if recovered_position is not None:
            if tradable_base > 0:
                transition(self.runtime, BotState.IN_POSITION)
                self._ensure_position_risk_plan()
            else:
                self.runtime.position = None
                transition(self.runtime, BotState.FLAT)
        elif tradable_base > 0:
            closed_candles = getattr(self, '_closed_candles', []) or []
            entry_price = float(getattr(closed_candles[-1], 'close', 0.0) if closed_candles else 0.0)
            self.runtime.position = Position(qty=tradable_base, entry_price=entry_price, source='live_balance_rehydrate', opened_at=utc_ms())
            self._ensure_position_risk_plan()
            transition(self.runtime, BotState.IN_POSITION)
        else:
            transition(self.runtime, BotState.FLAT)
        await self._startup_reconcile_persistent_state()
        self.runtime.ws_status = 'CONNECTED'
        self.logger.info('STATE_CHANGED', f'STOPPED -> {self.runtime.state}', {'reason': 'START_COMMAND'})
        self._save_runtime()
        self._running = True
        if not self._task_alive(self._market_task):
            self._market_task = asyncio.create_task(self._market_loop())
        if not self._task_alive(self._reconcile_task):
            self._reconcile_task = asyncio.create_task(self._reconcile_loop())
        return True


    async def stop(self) -> bool:
        was_running = self._running or self._task_alive(self._market_task) or self._task_alive(self._reconcile_task)
        self._running = False
        if self.runtime.pending and not self.runtime.pending.cancel_requested:
            await self.cancel_pending(reason='STOP_COMMAND')
        await self._cancel_task(self._market_task)
        await self._cancel_task(self._reconcile_task)
        self._market_task = None
        self._reconcile_task = None
        self.runtime.ws_status = 'DISCONNECTED'
        self.logger.info('WS_DISCONNECTED', 'WebSocket bağlantısı kapatıldı', {'reason': 'STOP_COMMAND'})
        prev = self.runtime.state
        transition(self.runtime, BotState.STOPPED)
        self.logger.info('STATE_CHANGED', f'{prev} -> STOPPED', {'reason': 'STOP_COMMAND'})
        self._save_runtime()
        return was_running

