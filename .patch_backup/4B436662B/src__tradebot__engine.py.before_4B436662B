        position = self.runtime.position
        if position is None or position.risk_plan is not None:
            return
        if position.qty <= 0 or position.entry_price <= 0:
            return
        try:
            position.risk_plan = build_risk_plan(position, self._latest_atr(), self.settings)
            self.logger.info('RISK_PLAN_READY', 'Pozisyon risk planı startup/recovery sırasında hazırlandı', {'atr': position.risk_plan.atr, 'entryPrice': position.risk_plan.entry_price, 'stopLoss': position.risk_plan.stop_loss, 'takeProfit': position.risk_plan.take_profit, 'source': 'startup_recovery'})
        except Exception as exc:
            self.logger.warn('RISK_PLAN_RECOVERY_SKIPPED', 'Pozisyon risk planı startup sırasında üretilemedi', {'error': str(exc)})

    def _risk_plan_execution_snapshot(self, position: Position | None, mark: float | None = None, *, mutate: bool = False) -> dict[str, Any]:
        if position is None:
            return {'present': False, 'ready': False, 'status': 'NO_POSITION', 'exit_required': False, 'should_submit_exit': False, 'exit_signal': None, 'exit_reason': None, 'exit_action': 'NONE'}
        if position.risk_plan is None:
            self._ensure_position_risk_plan()
        rp = position.risk_plan
        if rp is None:
            return {'present': True, 'ready': False, 'status': 'RISK_PLAN_MISSING', 'exit_required': False, 'should_submit_exit': False, 'exit_signal': None, 'exit_reason': None, 'exit_action': 'NONE'}
        now = utc_ms()
        mark_price = float(mark if mark is not None else (self._latest_mark_price() or position.entry_price))
        entry = float(position.entry_price or rp.entry_price or 0.0)
        original_stop = float(rp.stop_loss) if rp.stop_loss is not None else None
        take_profit = float(rp.take_profit) if rp.take_profit is not None else None
        active_stop = original_stop
        events: list[str] = []
        highest = float(rp.highest_mark_price or entry or mark_price)
        if mark_price > highest:
            highest = mark_price
            if mutate:
                rp.highest_mark_price = highest
        if getattr(self.settings, 'break_even_enabled', True) and rp.break_even_trigger_price is not None and mark_price >= float(rp.break_even_trigger_price):
            if not getattr(rp, 'break_even_armed', False):
                events.append('BREAK_EVEN_ARMED')
                if mutate:
                    rp.break_even_armed = True
                    rp.break_even_moved = True
                    self.logger.info('RISK_BREAK_EVEN_ARMED', 'Risk plan break-even seviyesi aktive edildi', {'symbol': self.settings.symbol, 'entryPrice': entry, 'markPrice': mark_price, 'triggerPrice': rp.break_even_trigger_price, 'breakEvenStop': rp.break_even_stop_price})
            if rp.break_even_stop_price is not None:
                active_stop = max(active_stop if active_stop is not None else float(rp.break_even_stop_price), float(rp.break_even_stop_price))
        trailing_allowed = bool(rp.trailing_enabled and getattr(self.settings, 'trailing_stop_enabled', True))
        if trailing_allowed and (not getattr(self.settings, 'trailing_only_after_break_even', True) or getattr(rp, 'break_even_armed', False) or (rp.break_even_trigger_price is not None and mark_price >= float(rp.break_even_trigger_price))):
            atr_value = rp.atr or self._latest_atr()
            if atr_value and atr_value > 0:
                candidate = highest - (float(atr_value) * float(getattr(self.settings, 'trailing_atr_multiplier', 1.0) or 1.0))
                prev_trailing = rp.trailing_stop
                if prev_trailing is None or candidate > float(prev_trailing):
                    if mutate:
                        rp.trailing_stop = candidate
                        rp.trailing_armed = True
                        self.logger.info('RISK_TRAILING_STOP_UPDATED', 'Risk plan trailing stop güncellendi', {'symbol': self.settings.symbol, 'markPrice': mark_price, 'highestMarkPrice': highest, 'trailingStop': candidate, 'previousTrailingStop': prev_trailing, 'atr': atr_value})
                    events.append('TRAILING_STOP_UPDATED')
                effective_trailing = rp.trailing_stop if rp.trailing_stop is not None else candidate
                active_stop = max(active_stop if active_stop is not None else effective_trailing, float(effective_trailing))
        stop_hit = active_stop is not None and mark_price <= float(active_stop)
        take_profit_hit = take_profit is not None and mark_price >= float(take_profit)
        partial_price = rp.partial_tp_price
        partial_hit = bool(getattr(self.settings, 'partial_take_profit_enabled', True) and partial_price is not None and mark_price >= float(partial_price) and not getattr(rp, 'partial_tp_triggered', False))
        max_hold_sec = getattr(self.settings, 'position_max_hold_sec', None)
        time_stop_hit = False
        if max_hold_sec and position.opened_at:
            time_stop_hit = now - int(position.opened_at) >= int(max_hold_sec) * 1000
        exit_reason = None
        exit_action = 'NONE'
        requested_qty = 0.0
        suggested_close_pct = 0.0
        if stop_hit:
            exit_reason = 'STOP_LOSS_HIT' if active_stop == original_stop else 'TRAILING_STOP_HIT'
