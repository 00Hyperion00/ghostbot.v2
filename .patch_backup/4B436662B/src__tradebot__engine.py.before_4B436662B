    def _entry_guard(self) -> tuple[bool, str]:
        if self.runtime.state == BotState.STOPPED.value or not getattr(self, '_running', True):
            return False, 'ENGINE_STOPPED'
        if self.runtime.pending is not None:
            return False, 'ENTRY_ALREADY_PENDING'
        if self.runtime.position is not None or self.runtime.state in {BotState.IN_POSITION.value, BotState.SELL_PENDING.value}:
            # cached position can be stale if live base balance is now zero
            if self.symbol_rules:
                base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance())
                tradable_base = round_down_to_step(max(base.free - base.dust, 0.0), self.symbol_rules.step_size)
                if tradable_base <= 0:
                    self.runtime.position = None
                    transition(self.runtime, BotState.FLAT)
                    self.logger.warn('STALE_POSITION_CLEARED', 'Cached pozisyon canlı bakiye ile uyuşmadığı için temizlendi', {'reason': 'ENTRY_GUARD'})
                else:
                    return False, 'POSITION_EXISTS'
            else:
                return False, 'POSITION_EXISTS'
        if self.runtime.state not in {BotState.FLAT.value, 'FLAT'}:
            return False, f'INVALID_ENTRY_STATE_{self.runtime.state}'
        if self.runtime.entry_lock_until and utc_ms() < self.runtime.entry_lock_until:
            return False, 'ENTRY_LOCK_ACTIVE'
        if not self.runtime.session.day_key:
            self.runtime.session.day_key = self._day_key()
        if self.settings.max_daily_trades and self.runtime.session.daily_trade_count >= self.settings.max_daily_trades:
            return False, 'DAILY_LIMIT_REACHED'
        if self._daily_loss_limit_reached():
            self._refresh_risk_kill_switch(reason='ENTRY_GUARD')
            return False, 'DAILY_LOSS_LIMIT_REACHED'
        if self.runtime.session.consecutive_losses >= self.settings.max_consecutive_losses:
            self._refresh_risk_kill_switch(reason='ENTRY_GUARD')
            return False, 'MAX_CONSECUTIVE_LOSSES_REACHED'
        if self.runtime.safe_mode:
            return False, 'SAFE_MODE_LOCKED'
        return True, 'OK'


    def _exit_guard(self) -> tuple[bool, str]:
        if self.runtime.state == BotState.STOPPED.value or not getattr(self, '_running', True):
            return False, 'ENGINE_STOPPED'
        if self.runtime.pending is not None:
            return False, 'EXIT_ALREADY_PENDING'
        if self.runtime.position is None:
            base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance()) if self.symbol_rules else Balance()
            if base.free > 0 and not is_effective_zero(base.free - base.dust, self.symbol_rules.step_size if self.symbol_rules else 1e-8):
                return True, 'RECOVERABLE_POSITION'
            return False, 'POSITION_NOT_FOUND'
        if self.symbol_rules:
            base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance())
            mark = self._latest_mark_price() or self.runtime.position.entry_price
            tradable_qty = round_down_to_step(max(base.free - base.dust, 0.0), self.symbol_rules.step_size)
            qty = min(round_down_to_step(self.runtime.position.qty, self.symbol_rules.step_size), tradable_qty)
            if qty <= 0:
                return False, 'EXIT_QTY_ZERO'
            if qty < self.symbol_rules.min_qty:
                return False, 'MIN_QTY_BLOCKED'
            if qty * mark < self.symbol_rules.min_notional * self.settings.min_notional_buffer_multiplier:
                return False, 'MIN_NOTIONAL_BLOCKED'
        return True, 'OK'


    async def _submit_entry(self, *, source: str, signal_meta: dict[str, Any] | None = None) -> None:
        if getattr(self, '_submit_lock', None) is None:
            self._submit_lock = asyncio.Lock()
        async with self._submit_lock:
            allowed, reason = self._entry_guard()
            if not allowed:
                self.runtime.auto_debug = f'{reason} | {reason}' if source == 'AUTO_SIGNAL' else self.runtime.auto_debug
                code = 'AUTO_ENTRY_BLOCKED' if source == 'AUTO_SIGNAL' else 'ENTRY_BLOCKED'
                message = 'Otomatik giriş guard tarafından engellendi' if source == 'AUTO_SIGNAL' else 'Giriş emri guard tarafından engellendi'
                self.logger.warn(code, message, {
                    'hasPending': self.runtime.pending is not None,
                    'hasPosition': self.runtime.position is not None,
                    'runtimeState': self.runtime.state,
                    'skipCode': reason,
                    **(signal_meta or {}),
                })
                self._save_runtime()
                return
            await self.sync_balances(log_code='BALANCES_READY')
            base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance())
            quote = self.runtime.balances.get(self.symbol_rules.quote_asset, Balance())
            if quote.free <= 0:
                self.logger.warn('ENTRY_BLOCKED', 'Quote bakiye yetersiz', {'skipCode': 'INSUFFICIENT_QUOTE_BALANCE', 'freeQuote': quote.free})
                return
            price_ref = (getattr(self, '_latest_book', {}) or {}).get('bestBid') or (getattr(self, '_closed_candles', [])[-1].close if getattr(self, '_closed_candles', []) else 0.0)
            price = round_price_to_tick(float(price_ref), self.symbol_rules.tick_size)
            try:
                sizing = build_entry_sizing_decision(
                    settings=self.settings,
                    symbol_rules=self.symbol_rules,
                    free_quote_balance=quote.free,
                    reference_price=price,
                )
            except PositionSizingError as error:
                self.logger.warn('ENTRY_BLOCKED', 'Giriş miktarı fail-closed sizing kontratı tarafından engellendi', {
                    'skipCode': stable_entry_skip_code_for_sizing_error(error.reason_code),
                    'sizingReasonCode': error.reason_code,
                    'price': price,
                    'freeQuote': quote.free,
                    'sizingMode': self.settings.sizing_mode,
                    'sizingContractVersion': '4B.4.3.6.6.27F',
                    'skipCodeCompatVersion': '4B.4.3.6.6.27F-H1',
                })
                return
            target_notional = sizing.quote_budget
            qty = sizing.quantity
            self.logger.info('ENTRY_SIZING_VERIFIED', 'Giriş miktarı fail-closed sizing kontratı ile doğrulandı', sizing.to_dict())
            client_id = self._build_client_order_id('TBBMO')
            if source == 'AUTO_SIGNAL':
                self.logger.info('AUTO_ENTRY_ACCEPTED', 'Otomatik giriş sinyali kabul edildi', signal_meta or {})
                self.runtime.auto_guard = f'BUY | key={signal_meta.get("signalKey", "-")} | {datetime.now().strftime("%H:%M:%S")}' if signal_meta else self.runtime.auto_guard
                self.runtime.auto_debug = f"AUTO_ENTRY_ACCEPTED | {(signal_meta or {}).get('signalReason', '')}"
            entry_preflight = getattr(self.exchange, 'run_entry_order_preflight', None)
            if not callable(entry_preflight):
                unavailable = blocked_entry_preflight_snapshot(
                    symbol=self.settings.symbol,
                    reason_code='PREFLIGHT_ADAPTER_UNAVAILABLE',
                    message='Entry preflight adapter unavailable; new-risk entry denied',
                    open_orders_check_performed=False,
                    open_orders_count=None,
                    order_test_performed=False,
                    order_test_ok=None,
                    policy_check_performed=False,
                    policy_allowed=None,
                ).to_log_payload()
                self.runtime.last_preflight = f'BLOCKED | ENTRY | PREFLIGHT_ADAPTER_UNAVAILABLE | {datetime.now().strftime("%d.%m.%Y %H:%M:%S")}'
                self.logger.warn('LIVE_PREFLIGHT_BLOCKED', 'Canlı giriş emri preflight adaptörü bulunamadığı için engellendi', {**unavailable,'causeReasonCode': 'ENTRY_PREFLIGHT_ADAPTER_UNAVAILABLE','notional': round(qty * price, 6),'price': price,'qty': qty,'route': self.settings.execution_mode.upper(),'side': 'BUY','symbol': self.settings.symbol})
                self._save_runtime()
                return
            try:
                preflight = await self.exchange.run_entry_order_preflight(
                    symbol=self.settings.symbol,
                    quantity=qty,
                    price=price,
                    client_order_id=client_id,
                )
            except OrderPreflightError as error:
                self.runtime.last_preflight = f'BLOCKED | ENTRY | {error.code} | {datetime.now().strftime("%d.%m.%Y %H:%M:%S")}'
                self.logger.warn('LIVE_PREFLIGHT_BLOCKED', 'Canlı giriş emri preflight tarafından engellendi', {**error.to_log_payload(),'notional': round(qty * price, 6),'price': price,'qty': qty,'route': self.settings.execution_mode.upper(),'side': 'BUY','symbol': self.settings.symbol})
                self._save_runtime()
                return
            except Exception as error:
                failed = blocked_entry_preflight_snapshot(
                    symbol=self.settings.symbol,
                    reason_code='PREFLIGHT_ADAPTER_CALL_FAILED',
                    message='Entry preflight adapter call failed; new-risk entry denied',
                    open_orders_check_performed=False,
                    open_orders_count=None,
                    order_test_performed=False,
                    order_test_ok=None,
                    policy_check_performed=False,
                    policy_allowed=None,
                ).to_log_payload()
                self.runtime.last_preflight = f'BLOCKED | ENTRY | PREFLIGHT_ADAPTER_CALL_FAILED | {datetime.now().strftime("%d.%m.%Y %H:%M:%S")}'
                self.logger.warn('LIVE_PREFLIGHT_BLOCKED', 'Canlı giriş emri preflight adaptör hatası nedeniyle engellendi', {**failed,'causeReasonCode': type(error).__name__,'notional': round(qty * price, 6),'price': price,'qty': qty,'route': self.settings.execution_mode.upper(),'side': 'BUY','symbol': self.settings.symbol})
                self._save_runtime()
                return
            self.runtime.last_preflight = f'OK | ENTRY | {self.settings.execution_mode.upper()} | {datetime.now().strftime("%d.%m.%Y %H:%M:%S")}'
            self.logger.info('LIVE_PREFLIGHT_OK', 'Canlı emir preflight başarılı', {**preflight,'notional': round(qty * price, 6),'price': price,'qty': qty,'route': self.settings.execution_mode.upper(),'side': 'BUY','symbol': self.settings.symbol})
            order = await self.exchange.create_limit_order(symbol=self.settings.symbol, side='BUY', quantity=qty, price=price, client_order_id=client_id)
            self.runtime.pending = PendingOrder(side='BUY', price=price, qty=qty, status=order.get('status', 'NEW'), order_id=str(order.get('orderId')) if order.get('orderId') is not None else None, client_order_id=client_id, source=source, submitted_at=utc_ms(), remaining_qty=qty)
            prev = self.runtime.state
            transition(self.runtime, BotState.BUY_PENDING)
            self.runtime.last_order_event = f'BUY pending @ {price} qty {qty} [passive/bid]'
            self.runtime.entry_lock_until = utc_ms() + (self.settings.auto_trade_cooldown_sec * 1000)
            self.logger.info('STATE_CHANGED', f'{prev} -> BUY_PENDING', {'reason': 'ENTRY_ORDER_SUBMITTED'})
            self.logger.info('ORDER_SUBMITTED', 'Giriş emri oluşturuldu', {'freeQuote': quote.free,'minNotional': self.symbol_rules.min_notional * self.settings.min_notional_buffer_multiplier,'mode': self.settings.execution_mode,'notional': round(qty * price, 6),'price': price,'priceMode': self.settings.force_entry_price_mode,'priceRef': 'bid','priceRefValue': price_ref,'qty': qty,'quoteAsset': self.symbol_rules.quote_asset,'side': 'BUY','sizingMode': sizing.sizing_mode,'sizingContractVersion': sizing.contract_version,'source': source,'targetNotional': target_notional,'sizingSnapshot': sizing.to_dict()})
            self._save_runtime()


    async def _submit_exit(self, *, source: str, signal_meta: dict[str, Any] | None = None, requested_qty_override: float | None = None) -> None:
        if getattr(self, '_exit_submit_lock', None) is None:
            self._exit_submit_lock = asyncio.Lock()
        async with self._exit_submit_lock:
            allowed, reason = self._exit_guard()
            if not allowed:
                code = 'AUTO_EXIT_BLOCKED' if source == 'AUTO_SIGNAL' else 'EXIT_BLOCKED'
                msg = 'Otomatik çıkış pozisyon bulunamadığı için atlandı' if source == 'AUTO_SIGNAL' else 'Çıkış emri guard tarafından engellendi'
                self.logger.warn(code, msg, {'hasPending': self.runtime.pending is not None,'hasPosition': self.runtime.position is not None,'runtimeState': self.runtime.state,'skipCode': reason,**(signal_meta or {})})
                self.runtime.auto_debug = f'{reason} | SELL için uygun state değil: {self.runtime.state}' if source == 'AUTO_SIGNAL' else self.runtime.auto_debug
                self._save_runtime()
                return
            await self.sync_balances(log_code='BALANCES_READY')
            base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance())
            latest_book = getattr(self, '_latest_book', {}) or {}
            price_ref = latest_book.get('bestAsk') if self.settings.force_exit_price_mode == 'passive' else latest_book.get('bestBid')
            price_ref = price_ref or (getattr(self, '_closed_candles', [])[-1].close if getattr(self, '_closed_candles', []) else 0.0)
            price = round_price_to_tick(float(price_ref), self.symbol_rules.tick_size)
            requested_qty = float(requested_qty_override) if requested_qty_override is not None else (self.runtime.position.qty if self.runtime.position else base.free)
            tradable_qty = round_down_to_step(max(base.free - base.dust, 0.0), self.symbol_rules.step_size)
            qty = min(round_down_to_step(requested_qty, self.symbol_rules.step_size), tradable_qty)
            if qty <= 0:
                self.logger.warn('EXIT_BLOCKED', 'Çıkış miktarı tradable lot olmadı', {'skipCode': 'EXIT_QTY_ZERO', 'requestedQty': requested_qty, 'liveFreeBase': base.free})
                return
            if qty < self.symbol_rules.min_qty or qty * price < self.symbol_rules.min_notional * self.settings.min_notional_buffer_multiplier:
                self.logger.warn('EXIT_BLOCKED', 'Çıkış emri minNotional/minQty nedeniyle engellendi', {'skipCode': 'MIN_NOTIONAL_BLOCKED', 'qty': qty, 'price': price, 'notional': qty * price})
                return
            exit_preflight = risk_reducing_exit_preflight_snapshot(symbol=self.settings.symbol).to_log_payload()
            self.runtime.last_preflight = f'OK | EXIT | POLICY_ONLY | {self.settings.execution_mode.upper()} | {datetime.now().strftime("%d.%m.%Y %H:%M:%S")}'
            self.logger.info('LIVE_PREFLIGHT_OK', 'Risk azaltıcı çıkış policy preflight başarılı', {**exit_preflight,'notional': round(qty * price, 6),'price': price,'qty': qty,'route': self.settings.execution_mode.upper(),'side': 'SELL','symbol': self.settings.symbol})
            client_id = self._build_client_order_id('TBSMO')
            if source == 'AUTO_SIGNAL':
                self.logger.info('AUTO_EXIT_TRIGGERED', 'Otomatik çıkış sinyali tetiklendi', signal_meta or {})
                self.runtime.auto_guard = f'SELL_PENDING | key={signal_meta.get("signalKey", "-")} | {datetime.now().strftime("%H:%M:%S")}' if signal_meta else self.runtime.auto_guard
                self.runtime.auto_debug = f'SELL_PENDING işlendi | {(signal_meta or {}).get("signalReason", "")}'
            order = await self.exchange.create_limit_order(symbol=self.settings.symbol, side='SELL', quantity=qty, price=price, client_order_id=client_id)
            self.runtime.pending = PendingOrder(side='SELL', price=price, qty=qty, status=order.get('status', 'NEW'), order_id=str(order.get('orderId')) if order.get('orderId') is not None else None, client_order_id=client_id, source=source, submitted_at=utc_ms(), remaining_qty=qty)
            prev = self.runtime.state
            transition(self.runtime, BotState.SELL_PENDING)
            self.runtime.last_order_event = f'SELL pending @ {price} qty {qty}'
            self.logger.info('STATE_CHANGED', f'{prev} -> SELL_PENDING', {'reason': 'EXIT_ORDER_SUBMITTED'})
            self.logger.info('ORDER_SUBMITTED', 'Çıkış emri oluşturuldu', {'baseAsset': self.symbol_rules.base_asset,'freeBase': base.free,'mode': self.settings.execution_mode,'notional': round(qty * price, 6),'price': price,'priceMode': self.settings.force_exit_price_mode,'priceRef': 'bid','priceRefValue': price_ref,'qty': qty,'side': 'SELL','source': source,'riskExitReason': (signal_meta or {}).get('riskExitReason'),'riskExitAction': (signal_meta or {}).get('riskExitAction')})
            self._save_runtime()


    def _pending_grace_window_ms(self) -> int:
        return max(5_000, int(getattr(self.settings, 'order_timeout_sec', 20) * 1000 / 2))

    async def _reconcile_pending_order(self) -> None:
        pending = self.runtime.pending
        if not pending:
            return
        now = utc_ms()
        pending.last_reconcile_at = now
        pending.reconcile_attempts += 1
        self._set_reconciliation_snapshot(pending=pending, phase='POLL', action='FETCH_LIVE_ORDER')
        try:
            order = await self.exchange.fetch_order(self.settings.symbol, order_id=pending.order_id, client_order_id=pending.client_order_id)
        except Exception as exc:
            pending.last_reconcile_error = str(exc)
            self._set_reconciliation_snapshot(pending=pending, phase='FETCH_LIVE_ORDER', action='POLL_AGAIN', error=str(exc))
            order = None
        await self.sync_balances(log_code='BALANCES_READY')
        base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance())
        if order:
            status = order.get('status', pending.status)
            executed_qty = float(order.get('executedQty', pending.partial_executed_qty) or 0)
            orig_qty = float(order.get('origQty', pending.qty) or pending.qty)
            pending.status = status
            pending.last_live_status = status
            pending.last_status_at = now
            pending.partial_executed_qty = executed_qty
            pending.last_fill_qty = executed_qty
            pending.last_fill_price = float(order.get('price') or pending.price or 0) or pending.price
            pending.remaining_qty = max(orig_qty - executed_qty, 0.0)
            self._set_reconciliation_snapshot(pending=pending, phase='LIVE_ORDER_STATUS', action='POLL_AGAIN', order=order)
            if status in {'PARTIALLY_FILLED'} and executed_qty > 0:
                self.logger.info('PENDING_RECONCILE_PARTIAL', 'Pending emir kısmi dolum olarak güncellendi', {'clientOrderId': pending.client_order_id, 'orderId': pending.order_id, 'executedQty': executed_qty, 'remainingQty': pending.remaining_qty, 'side': pending.side, 'status': status})
            if status == 'FILLED':
                self._set_reconciliation_snapshot(pending=pending, phase='LIVE_ORDER_FILLED', action='COMMIT_FILL', order=order, reason='LIVE_ORDER_FILLED', fill_source='live_order')
                await self._commit_filled_pending(pending, source='live_order', fill_price=float(order.get('price') or pending.price or 0) or pending.price, fill_qty=executed_qty or pending.qty)
                return
            if status in {'CANCELED', 'EXPIRED', 'REJECTED'}:
                self._set_reconciliation_snapshot(pending=pending, phase='LIVE_ORDER_TERMINAL', action='CLEAR_PENDING', order=order, reason=f'LIVE_ORDER_{status}')
                await self._clear_pending('LIVE_CANCELED', pending)
                return
        if order is None:
            pending.missing_count = int(getattr(pending, 'missing_count', 0)) + 1
            pending.last_reconcile_reason = 'LIVE_ORDER_NOT_FOUND'
            self._set_reconciliation_snapshot(pending=pending, phase='LIVE_ORDER_NOT_FOUND', action='POLL_AGAIN', reason='LIVE_ORDER_NOT_FOUND')
            self.logger.warn('PENDING_RECONCILE_NOT_FOUND', 'Pending emir canlı sorguda bulunamadı', {'orderId': pending.order_id, 'missingCount': pending.missing_count})
        if pending.side == 'BUY':
            tradable_base = round_down_to_step(max(base.free - base.dust, 0.0), self.symbol_rules.step_size)
            if tradable_base >= round_down_to_step(pending.qty * 0.995, self.symbol_rules.step_size):
                self.logger.info('LIVE_FILL_RECONCILED', 'Canlı emir bakiye recovery dolumu doğruladı', {'clientOrderId': pending.client_order_id, 'evidence': 'BASE_FULL', 'orderId': pending.order_id, 'price': pending.price, 'qty': pending.qty, 'reason': 'BALANCE_SYNC_DELTA', 'remainingQty': 0, 'side': pending.side, 'source': 'live_balance_reconcile', 'symbol': self.settings.symbol}, dedupe_ms=8_000)
                self._set_reconciliation_snapshot(pending=pending, phase='BALANCE_FILL_EVIDENCE', action='COMMIT_FILL', reason='BALANCE_SYNC_DELTA', fill_source='live_balance_reconcile')
                await self._commit_filled_pending(pending, source='live_balance_reconcile', fill_price=pending.price, fill_qty=pending.qty)
                return
        elif pending.side == 'SELL':
            tradable_base = round_down_to_step(max(base.free - base.dust, 0.0), self.symbol_rules.step_size)
            if tradable_base <= 0:
                self.logger.info('LIVE_FILL_RECONCILED', 'Canlı emir bakiye ve açık emir uzlaşması ile dolu sayıldı', {'clientOrderId': pending.client_order_id, 'orderId': pending.order_id, 'price': pending.price, 'qty': pending.qty, 'remainingQty': 0, 'side': pending.side, 'source': 'live_balance_reconcile', 'symbol': self.settings.symbol}, dedupe_ms=8_000)
                self._set_reconciliation_snapshot(pending=pending, phase='BALANCE_FILL_EVIDENCE', action='COMMIT_FILL', reason='BALANCE_SYNC_DELTA', fill_source='live_balance_reconcile')
                await self._commit_filled_pending(pending, source='live_balance_reconcile', fill_price=pending.price, fill_qty=pending.qty)
                return
        open_orders = await self.exchange.fetch_open_orders(self.settings.symbol)
        still_open = any(str(order.get('orderId')) == str(pending.order_id) or str(order.get('clientOrderId')) == str(pending.client_order_id) for order in open_orders)
        self._set_reconciliation_snapshot(pending=pending, phase='OPEN_ORDER_CROSSCHECK', action='WAIT' if still_open else 'POLL_AGAIN', open_orders=open_orders)
        grace_expired = (now - int(pending.submitted_at or 0)) >= self._pending_grace_window_ms()
        if order is None and not still_open and grace_expired and int(getattr(pending, 'missing_count', 0)) >= 3:
            self._set_reconciliation_snapshot(pending=pending, phase='ORPHAN_PENDING_CLEANUP', action='CLEAR_PENDING', open_orders=open_orders, reason='ORPHAN_PENDING_CLEANUP')
            self.logger.warn('ORPHAN_PENDING_CLEANUP', 'Canlıda bulunmayan orphan pending temizlendi', {'orderId': pending.order_id, 'side': pending.side})
            await self._clear_pending('ORPHAN_PENDING_CLEANED', pending)
            return
        max_attempts_reached = pending.reconcile_attempts >= max(8, getattr(self.settings, 'order_timeout_sec', 20) // 2)
        if (max_attempts_reached or grace_expired) and still_open and not pending.cancel_requested:
            pending.deferred = True
            self._set_reconciliation_snapshot(pending=pending, phase='RECONCILIATION_DEFERRED', action='REQUEST_CANCEL', open_orders=open_orders, reason='MAX_ATTEMPTS_REACHED')
            self.logger.warn('RECONCILIATION_DEFERRED', 'Canlı emir uzlaşması deneme sınırına ulaştı; beklemeye alındı', {'attempts': pending.reconcile_attempts, 'clientOrderId': pending.client_order_id, 'orderId': pending.order_id, 'reason': 'MAX_ATTEMPTS_REACHED', 'side': pending.side, 'symbol': self.settings.symbol}, dedupe_ms=15_000)
            try:
                await self.exchange.cancel_order(symbol=self.settings.symbol, order_id=pending.order_id, client_order_id=pending.client_order_id)
                pending.cancel_requested = True
                pending.cancel_requested_at = utc_ms()
                pending.status = 'CANCEL_REQUESTED'
                self._set_reconciliation_snapshot(pending=pending, phase='ORDER_CANCEL_REQUESTED', action='WAIT_CANCEL_CONFIRMATION', open_orders=open_orders, reason='ORPHAN_PENDING_CLEANUP')
                self.logger.warn('ORDER_CANCEL_REQUESTED', 'Bekleyen canlı emir için iptal talebi gönderildi', {'orderId': pending.order_id, 'reason': 'ORPHAN_PENDING_CLEANUP', 'side': pending.side})
            except Exception as exc:
                pending.last_reconcile_error = str(exc)
                self._set_reconciliation_snapshot(pending=pending, phase='ORDER_CANCEL_ERROR', action='POLL_AGAIN', open_orders=open_orders, error=str(exc))
                self.logger.warn('ORDER_CANCEL_WARN', 'Canlı emir iptal sorgusu uyarı verdi', {'error': str(exc), 'orderId': pending.order_id})
        self._save_runtime()


    async def _finalize_exit_filled(self, pending: PendingOrder, *, source: str, fill_price: float, fill_qty: float) -> None:
        prev = self.runtime.state
        position = self.runtime.position
        pnl = 0.0
        remaining_qty = 0.0
        if position:
            pnl = (fill_price - position.entry_price) * fill_qty
            remaining_qty = max(position.qty - fill_qty, 0.0)
        self.runtime.pending = None
        self.runtime.active_exit_intent = None
        self.runtime.last_order_event = f'SELL filled @ {fill_price}'
        if position and remaining_qty > max(self.symbol_rules.min_qty if self.symbol_rules else 0.0, 1e-12):
            position.qty = remaining_qty
            self.runtime.position = position
            transition(self.runtime, BotState.IN_POSITION)
            self.logger.info('ORDER_PARTIALLY_FILLED', 'Kısmi çıkış emri doldu; pozisyon açık kaldı', {'baseAsset': self.symbol_rules.base_asset if self.symbol_rules else None, 'orderId': pending.order_id, 'pnl': round(pnl, 6), 'price': fill_price, 'qty': fill_qty, 'remainingQty': remaining_qty, 'side': 'SELL', 'source': source})
            self.logger.info('STATE_CHANGED', f'{prev} -> {self.runtime.state}', {'reason': 'ORDER_PARTIALLY_FILLED'})
            self._record_performance_exit(position, pending, fill_price=fill_price, fill_qty=fill_qty, pnl=pnl, remaining_qty=remaining_qty, source=source, closed=False)
            self._save_runtime()
            return
        else:
            transition(self.runtime, BotState.FLAT)
            self.runtime.position = None
            self.logger.info('ORDER_FILLED', 'Çıkış emri doldu', {'baseAsset': self.symbol_rules.base_asset if self.symbol_rules else None, 'orderId': pending.order_id, 'pnl': round(pnl, 6), 'price': fill_price, 'qty': fill_qty, 'side': 'SELL', 'source': source})
            self.logger.info('POSITION_CLOSED', 'Pozisyon kapandı', {'baseAsset': self.symbol_rules.base_asset if self.symbol_rules else None, 'exitSource': pending.source, 'fillSource': source, 'pnl': round(pnl, 6), 'price': fill_price, 'qty': fill_qty, 'quoteAsset': self.symbol_rules.quote_asset if self.symbol_rules else None, 'symbol': self.settings.symbol})
            self.runtime.session.daily_trade_count += 1
            self.runtime.session.daily_realized_pnl += pnl
            self.runtime.session.last_closed_pnl = pnl
            self.runtime.session.consecutive_losses = self.runtime.session.consecutive_losses + 1 if pnl < 0 else 0
            self.logger.info('STATE_CHANGED', f'{prev} -> {self.runtime.state}', {'reason': 'ORDER_FILLED'})
            self.logger.info('RISK_STATS_UPDATED', 'Risk istatistikleri güncellendi', {'consecutiveLosses': self.runtime.session.consecutive_losses, 'dailyRealizedPnl': round(self.runtime.session.daily_realized_pnl, 6), 'dailyTradeCount': self.runtime.session.daily_trade_count, 'lastClosedPnl': round(pnl, 6), 'quoteAsset': self.symbol_rules.quote_asset if self.symbol_rules else None})
            self._record_performance_exit(position, pending, fill_price=fill_price, fill_qty=fill_qty, pnl=pnl, remaining_qty=0.0, source=source, closed=True)
            self._refresh_risk_kill_switch(reason='EXIT_FILLED')

    async def _commit_filled_pending(self, pending: PendingOrder, *, source: str, fill_price: float, fill_qty: float) -> None:
        self._set_reconciliation_snapshot(pending=pending, phase='FILL_COMMIT', action='COMMIT_FILL', reason='FILLED_COMMITTED', fill_source=source)
        if pending.side == 'BUY':
            prev = self.runtime.state
            transition(self.runtime, BotState.IN_POSITION)
            risk_plan = build_risk_plan(Position(qty=fill_qty, entry_price=fill_price, source=pending.source, order_id=pending.order_id, client_order_id=pending.client_order_id, opened_at=utc_ms()), self._latest_atr(), self.settings)
            self.runtime.position = Position(qty=fill_qty, entry_price=fill_price, source=pending.source, order_id=pending.order_id, client_order_id=pending.client_order_id, opened_at=utc_ms(), risk_plan=risk_plan)
            self.runtime.pending = None
            self.runtime.last_order_event = f'BUY filled @ {fill_price}'
            self.logger.info('STATE_CHANGED', f'{prev} -> IN_POSITION', {'reason': 'ORDER_FILLED'})
            self.logger.info('ORDER_FILLED', 'Giriş emri doldu', {'orderId': pending.order_id, 'price': fill_price, 'qty': fill_qty, 'quoteAsset': self.symbol_rules.quote_asset if self.symbol_rules else None, 'side': 'BUY', 'source': source})
            self.logger.info('RISK_PLAN_READY', 'Pozisyon risk planı hazırlandı', {'atr': risk_plan.atr,'entryPrice': risk_plan.entry_price,'openRiskQuote': risk_plan.open_risk_quote,'plannedRR': risk_plan.planned_rr,'quoteAsset': self.symbol_rules.quote_asset if self.symbol_rules else None,'stopLoss': risk_plan.stop_loss,'takeProfit': risk_plan.take_profit})
            self._record_performance_entry(pending, fill_price=fill_price, fill_qty=fill_qty, source=source)
            self._save_runtime()
        else:
            await self._finalize_exit_filled(pending, source=source, fill_price=fill_price, fill_qty=fill_qty)


    async def _clear_pending(self, reason: str, pending: PendingOrder) -> None:
        prev = self.runtime.state
        self._set_reconciliation_snapshot(pending=pending, phase='PENDING_CLEARED', action='CLEAR_PENDING', reason=reason)
        self.runtime.pending = None
        if prev == BotState.BUY_PENDING.value:
            transition(self.runtime, BotState.FLAT)
        elif prev == BotState.SELL_PENDING.value and self.runtime.position:
            transition(self.runtime, BotState.IN_POSITION)
        self.logger.warn('ORDER_CANCELED', 'Bekleyen emir iptal edildi', {'orderId': pending.order_id, 'priceMode': self.settings.force_entry_price_mode if pending.side == 'BUY' else self.settings.force_exit_price_mode, 'priceRef': 'bid', 'reason': reason, 'side': pending.side})
        self.logger.info('STATE_CHANGED', f'{prev} -> {self.runtime.state}', {'reason': reason})
        self._save_runtime()

    def _expire_safe_mode(self) -> None:
        if self.runtime.safe_mode and self.runtime.safe_mode_until and utc_ms() >= self.runtime.safe_mode_until:
            source = getattr(self.runtime, 'safe_mode_source', None)
            self.runtime.safe_mode = False
            self.runtime.safe_mode_until = None
            self.runtime.safe_mode_source = None
            self.runtime.safe_mode_reason_code = None
            if source:
                self.logger.info('SAFE_MODE_AUTO_EXPIRED', 'Otomatik safe mode süresi doldu', {'source': source})
            self._save_runtime()

    def _daily_loss_limit_reached(self) -> bool:
        max_pct = float(getattr(self.settings, 'max_daily_loss_pct', 0.0) or 0.0)
        if max_pct <= 0:
            return False
        quote_asset = self.symbol_rules.quote_asset if self.symbol_rules else 'USDT'
        quote = self.runtime.balances.get(quote_asset, Balance())
        reference = max(quote.free, 1.0)
        return self.runtime.session.daily_realized_pnl <= -(reference * max_pct / 100.0)

    def _enable_auto_safe_mode(self, *, source: str, reason_code: str, log_code: str, reason: str) -> None:
        until = utc_ms() + int(getattr(self.settings, 'safe_mode_cooldown_min', 60) * 60 * 1000)
        already = self.runtime.safe_mode and self.runtime.safe_mode_source == source and self.runtime.safe_mode_reason_code == reason_code
        self.runtime.safe_mode = True
        self.runtime.safe_mode_source = source
        self.runtime.safe_mode_reason_code = reason_code
        if not already:
            self.runtime.safe_mode_until = until
            self.logger.warn(log_code, 'Risk kill switch tetiklendi', {'reason': reason, 'reasonCode': reason_code, 'source': source})
            self.logger.warn('SAFE_MODE_AUTO_ENABLED', 'Otomatik safe mode etkinleştirildi', {'source': source, 'reasonCode': reason_code, 'until': until})
        self._save_runtime()

    def _refresh_risk_kill_switch(self, *, reason: str) -> None:
        if self._daily_loss_limit_reached():
            self._enable_auto_safe_mode(source='daily_loss', reason_code='DAILY_LOSS_LIMIT_REACHED', log_code='DAILY_LOSS_LOCKED', reason=reason)
            return
        if self.runtime.session.consecutive_losses >= getattr(self.settings, 'max_consecutive_losses', 999999):
            self._enable_auto_safe_mode(source='consecutive_losses', reason_code='MAX_CONSECUTIVE_LOSSES_REACHED', log_code='CONSECUTIVE_LOSS_LOCKED', reason=reason)

    def _health_snapshot(self) -> dict[str, Any]:
        base = Balance()
        if self.symbol_rules:
            base = self.runtime.balances.get(self.symbol_rules.base_asset, Balance())
        has_position = self.runtime.position is not None
        has_pending = self.runtime.pending is not None
        position_mismatch = has_position and self.symbol_rules and round_down_to_step(max(base.free - base.dust, 0.0), self.symbol_rules.step_size) <= 0
        account_consistency = 'WARNING' if position_mismatch else 'HEALTHY'
        return {
            'engine_running': bool(getattr(self, '_running', False)),
            'ws_connected': self.runtime.ws_status == 'CONNECTED',
            'has_pending': has_pending,
            'has_position': has_position,
            'account_consistency': account_consistency,
            'position_consistency': 'WARNING' if position_mismatch else 'HEALTHY',
            'pending_consistency': 'HEALTHY',
            'active_anomaly_code': 'BALANCE_POSITION_MISMATCH' if position_mismatch else None,
        }

