def _utc_stamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def _import(name: str) -> tuple[Any | None, str | None]:
    importlib.invalidate_caches()
    try:
        return importlib.import_module(name), None
    except Exception as exc:
        return None, f"{type(exc).__name__}: {exc}"


def _contract(module: Any | None, module_name: str, symbol: str, *, callable_required: bool) -> dict[str, Any]:
    value = getattr(module, symbol, None) if module is not None else None
    present = value is not None
    ready = present and (callable(value) if callable_required else isinstance(value, str))
    return {
        "module": module_name,
        "symbol": symbol,
        "module_imported": module is not None,
        "symbol_present": present,
        "symbol_type": type(value).__name__ if present else None,
        "callable_required": callable_required,
        "contract_ready": ready,
        "restored_by_patch": ready,
    }


def _snapshot_ok(build_fn: Any, root: Path) -> tuple[bool, dict[str, Any] | None, str | None]:
    try:
        snapshot = build_fn(project_root=root)
    except Exception as exc:
        return False, None, f"{type(exc).__name__}: {exc}"
    if not isinstance(snapshot, dict):
        return False, None, "snapshot is not dict"
    required_true = (
        "production_hardening_signature_compatibility_v2",
        "production_hardening_signature_compatibility_h3",
        "production_hardening_signature_compatibility_h4",
        "production_hardening_import_finalization_h5",
        "production_hardening_import_finalization_h6",
    )
    required_false = (
        "paper_submit_enabled_by_patch",
        "paper_order_submit_performed",
        "network_order_submit_performed",
        "network_request_performed",
        "approved_for_live_real",
        "exchange_submit_performed",
        "private_api_access_allowed",
    )
    ok = snapshot.get("ok") is True and all(snapshot.get(k) is True for k in required_true) and all(snapshot.get(k) is False for k in required_false)
    return ok, snapshot, None


def build_phase61_h6_report(project_root: str | Path = ".") -> dict[str, Any]:
    root = Path(project_root).resolve()
    production_module, production_error = _import("tradebot.production_hardening")
    cockpit_module, cockpit_error = _import("tradebot.operator_cockpit_v2_read_only")
    contracts = [_contract(production_module, "tradebot.production_hardening", s, callable_required=True) for s in PRODUCTION_SYMBOLS]
    contracts += [_contract(cockpit_module, "tradebot.operator_cockpit_v2_read_only", s, callable_required=False) for s in COCKPIT_CONSTANTS]
    contracts += [_contract(cockpit_module, "tradebot.operator_cockpit_v2_read_only", s, callable_required=True) for s in COCKPIT_FUNCTIONS]
