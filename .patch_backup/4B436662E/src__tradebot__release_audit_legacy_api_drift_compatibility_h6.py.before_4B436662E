    if callable(build_fn):
        snapshot_ok, snapshot, snapshot_error = _snapshot_ok(build_fn, root)
    for item in contracts:
        if item["symbol"] == "build_production_hardening_snapshot":
            item["contract_ready"] = item["restored_by_patch"] = item["contract_ready"] and snapshot_ok
    ready_count = sum(1 for x in contracts if x.get("contract_ready") is True)
