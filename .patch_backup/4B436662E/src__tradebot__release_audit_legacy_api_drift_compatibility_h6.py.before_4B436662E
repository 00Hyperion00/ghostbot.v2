def _phase_alias(report: dict[str, Any], phase: str) -> dict[str, Any]:
    r = dict(report)
    r["phase"] = phase
    r[f"phase_{phase.lower().replace('-', '_')}_closed"] = r["ok"]
    if phase == "61-H4":
        r["phase_61_h4_closed"] = r["ok"]
    if phase == "61-H5":
        r["phase_61_h5_closed"] = r["ok"]
    return r


def build_phase61_h5_report(project_root: str | Path = ".") -> dict[str, Any]:
    return _phase_alias(build_phase61_h6_report(project_root=project_root), "61-H5")


def build_phase61_h4_report(project_root: str | Path = ".") -> dict[str, Any]:
    return _phase_alias(build_phase61_h6_report(project_root=project_root), "61-H4")


def write_report(report: dict[str, Any], reports_dir: Path) -> Path:
    reports_dir.mkdir(parents=True, exist_ok=True)
    suffix = "ready" if report.get("ok") else "blocked"
    path = reports_dir / f"4B436661_H6_production_hardening_import_finalization_cockpit_callable_{_utc_stamp().lower()}_{suffix}.json"
    path.write_text(json.dumps(report, indent=2, sort_keys=True), encoding="utf-8")
    return path


def main() -> int:
    parser = argparse.ArgumentParser(description=PATCH_NAME)
    parser.add_argument("--project-root", default=".")
    parser.add_argument("--reports-dir", default=None)
    parser.add_argument("--once-json", action="store_true")
    args = parser.parse_args()
    report = build_phase61_h6_report(Path(args.project_root))
    if args.reports_dir:
        report["report_path"] = str(write_report(report, Path(args.reports_dir)))
    print(json.dumps(report, sort_keys=True) if args.once_json else json.dumps(report, indent=2, sort_keys=True))
    return 0 if report.get("ok") else 1


if __name__ == "__main__":
    raise SystemExit(main())
