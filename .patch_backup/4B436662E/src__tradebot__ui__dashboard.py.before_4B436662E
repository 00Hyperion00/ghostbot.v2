    def show_page(self, name: str) -> None:
        if name not in self.pages:
            return
        self._active_page = name
        for page_name, page in self.pages.items():
            if page_name == name:
                raise_fn = getattr(page, 'tkraise', None)
                if callable(raise_fn):
                    raise_fn()
            button = self.nav_buttons.get(page_name)
            if button is not None:
                button.configure(fg_color=('gray75', 'gray30') if page_name == name else 'transparent')
