    def refresh_chart(self) -> None:
        if not MATPLOTLIB_AVAILABLE or not self.chart_ax or not self.chart_canvas:
            return
        symbol = (self.chart_symbol_entry.get().strip().upper() or self.form['symbol'].get().strip().upper() or 'ETHUSDT')
        interval = self.chart_interval.get()
        try:
            candles = self.api_get(f'/market/klines?symbol={symbol}&interval={interval}&limit=120', timeout=4.0)
            if not self._last_logs:
                self._last_logs = self.api_get('/logs?limit=0&order=asc', timeout=2.5)
            self._render_chart(candles, self._last_logs, symbol=symbol, interval=interval)
        except Exception as exc:
            self._render_chart_placeholder(f'Grafik alınamadı: {exc}')

    def _render_chart_placeholder(self, message: str) -> None:
        if not MATPLOTLIB_AVAILABLE or not self.chart_ax or not self.chart_canvas:
            return
        self.chart_ax.clear()
        self.chart_ax.set_title('Market Chart')
        self.chart_ax.text(0.5, 0.5, message, ha='center', va='center', transform=self.chart_ax.transAxes)
        self.chart_ax.set_xticks([])
        self.chart_ax.set_yticks([])
        self.chart_canvas.draw_idle()
        self.chart_info.configure(text=message)

    def _render_chart(self, candles: list[dict[str, Any]], logs: list[dict[str, Any]], *, symbol: str, interval: str) -> None:
        if not candles:
            self._render_chart_placeholder('Grafik verisi yok')
            return
        closes = [float(candle['close']) for candle in candles]
        indices = list(range(len(candles)))
        markers = extract_signal_markers(logs, candles)

        self.chart_ax.clear()
        self.chart_ax.plot(indices, closes, linewidth=1.6, label=f'{symbol} close')
        for signal, marker, color, alpha, size in [
            ('BUY', '^', 'green', 0.9, 60),
            ('SELL', 'v', 'red', 0.9, 60),
            ('HOLD', 'o', 'gray', 0.25, 18),
        ]:
            points = markers.get(signal) or []
            if not points:
                continue
            xs = [point[0] for point in points]
            ys = [point[1] for point in points]
            self.chart_ax.scatter(xs, ys, marker=marker, alpha=alpha, s=size, label=signal, c=color)
        self.chart_ax.set_title(f'{symbol} | {interval} | Binance chart + signal markers')
        self.chart_ax.set_xlabel('Candle index')
        self.chart_ax.set_ylabel('Close')
        self.chart_ax.grid(True, alpha=0.25)
        self.chart_ax.legend(loc='upper left')
        self.chart_canvas.draw_idle()
        self.chart_info.configure(
            text=(
                f"Candles: {len(candles)} | BUY: {len(markers['BUY'])} | "
                f"SELL: {len(markers['SELL'])} | HOLD: {len(markers['HOLD'])}"
            )
        )

    def _set_text(self, widget: ctk.CTkTextbox | Any, text: str) -> None:
        if widget is None:
            return
        configure = getattr(widget, 'configure', None)
        delete = getattr(widget, 'delete', None)
        insert = getattr(widget, 'insert', None)
        if callable(configure):
            configure(state='normal')
        if callable(delete):
            try:
                delete('1.0', 'end')
            except Exception:
                pass
        if callable(insert):
            try:
                insert('end', text)
            except Exception:
                pass
        if callable(configure):
            configure(state='disabled')

    def _append_backend(self, text: str) -> None:
        backend_box = safe_obj_getattr(self, 'backend_box', None)
        if backend_box is None:
            return
        backend_box.configure(state='normal')
        backend_box.insert('end', text + '\n')
        if hasattr(backend_box, 'see'):
            backend_box.see('end')
        backend_box.configure(state='disabled')


    def _extract_training_output_path(self, line: str) -> str | None:
        import ast
        try:
            payload = ast.literal_eval(line.strip())
        except Exception:
            return None
        if isinstance(payload, dict):
            out = payload.get('output')
            return str(out) if out else None
        return None

    def _resolve_training_output_path(self, symbol: str) -> Path:
        current = self.form.get('ai_model_path')
        current_value = current.get() if current is not None and hasattr(current, 'get') else ''
        path = Path(current_value or f'models/{symbol}_model.ubj')
        if path.suffix.lower() != '.ubj':
            path = path.with_suffix('.ubj')
        if not path.is_absolute():
            path = self.project_root / path
        path.parent.mkdir(parents=True, exist_ok=True)
        return path

    def on_close(self) -> None:
        try:
            if self._backend_owned:
                self.stop_backend()
        except Exception:
            pass
        self.destroy()



def launch_dashboard(config_path: str, api_host: str = '127.0.0.1', api_port: int = 8787) -> None:
