def build_audit_summary_text(payload: _Tb20tAny = None, logs: _Tb20tAny = None) -> str:
    data = _tb20t_dict(payload)
    summary = _tb20t_dict(data.get('summary') or data.get('counts') or {})
    raw_events = logs if logs is not None else data.get('events') or data.get('items') or data.get('logs') or []
    events = [dict(item) for item in _tb20t_list(raw_events) if isinstance(item, dict)]
    categories = dict(_tb20t_dict(summary.get('categories') or summary.get('category_counts')))
    severities = dict(_tb20t_dict(summary.get('severities') or summary.get('severity_counts')))
    codes = dict(_tb20t_dict(summary.get('codes') or summary.get('code_counts')))
    levels: dict[str, int] = {}
    if not categories and not severities and not codes:
        for item in events:
            categories[_tb20t_event_category(item)] = categories.get(_tb20t_event_category(item), 0) + 1
            severities[_tb20t_severity(item)] = severities.get(_tb20t_severity(item), 0) + 1
            codes[str(item.get('code') or '-')] = codes.get(str(item.get('code') or '-'), 0) + 1
            levels[_tb20t_level(item)] = levels.get(_tb20t_level(item), 0) + 1
    warn_count = _tb20t_int(severities.get('warning'), 0) + _tb20t_int(levels.get('WARN'), 0)
    err_count = _tb20t_int(severities.get('error'), 0) + _tb20t_int(levels.get('ERROR'), 0)
    total = _tb20t_int(data.get('total') or data.get('total_events') or summary.get('total') or len(events), len(events))
    rendered = len(events) if events else _tb20t_int(data.get('rendered_count') or data.get('filtered_events') or summary.get('rendered_count'), 0)
    return '\n'.join([
        'Audit Viewer',
        '------------',
        f'Contract        : {AUDIT_VIEWER_CONTRACT_VERSION}',
        f'Total events    : {total}',
        f'Rendered count  : {rendered}',
        f'Filtered events : {rendered}',
        f'Warnings/errors : {warn_count} / {err_count}',
        f'Categories      : {_tb20t_count_line(categories)}',
        f'Severities      : {_tb20t_count_line(severities)}',
        f'Codes           : {_tb20t_count_line(codes)}',
        f'Top codes       : {_tb20t_count_line(codes)}',
    ])


def build_audit_query_path(*, limit: int = 50, order: str = 'desc', level: _Tb20tAny = None, code: _Tb20tAny = None, code_prefix: _Tb20tAny = None, contains: _Tb20tAny = None, q: _Tb20tAny = None, category: _Tb20tAny = None, severity: _Tb20tAny = None, correlation: _Tb20tAny = None, **extra: _Tb20tAny) -> str:
    params: dict[str, _Tb20tAny] = {'limit': int(limit), 'order': str(order or 'desc').lower()}
    for key, value in {'level': level, 'code': code, 'code_prefix': code_prefix, 'category': category, 'severity': severity, 'correlation': correlation}.items():
        if not _tb20t_is_all(value):
            params[key] = str(value).upper() if key in {'code', 'code_prefix'} else str(value)
    query = q if not _tb20t_is_all(q) else contains
    if not _tb20t_is_all(query):
        params['q'] = str(query)
    params.update({k: v for k, v in extra.items() if v not in (None, '')})
    return '/events/audit?' + _tb20t_urlencode(params)


