    # ---------- config ----------
    def load_config_into_form(self) -> None:
        payload: dict[str, Any] = {}
        if self.config_path.exists():
            payload = yaml.safe_load(self.config_path.read_text(encoding='utf-8')) or {}
        else:
            self._append_backend(f'Config bulunamadı: {self.config_path}')
        for key, widget in self.form.items():
            value = payload.get(key)
            if value is None:
                continue
            if isinstance(widget, ctk.CTkEntry):
                widget.delete(0, 'end')
                widget.insert(0, str(value))
            elif isinstance(widget, ctk.CTkOptionMenu):
                widget.set(str(value))
            elif isinstance(widget, ctk.CTkSwitch):
                if bool(value):
                    widget.select()
                else:
                    widget.deselect()
        symbol_value = str(payload.get('symbol') or 'ETHUSDT')
        self.train_symbol.delete(0, 'end')
        self.train_symbol.insert(0, symbol_value)
        self.chart_symbol_entry.delete(0, 'end')
        self.chart_symbol_entry.insert(0, symbol_value)
        if payload.get('ai_model_path'):
            models = self.scan_models()
            self.model_combo.configure(values=models)
            if payload['ai_model_path'] in models:
                self.model_combo.set(payload['ai_model_path'])

    def save_config(self) -> None:
        existing: dict[str, Any] = {}
        if self.config_path.exists():
            existing = yaml.safe_load(self.config_path.read_text(encoding='utf-8')) or {}
        for key, widget in self.form.items():
            if isinstance(widget, ctk.CTkEntry):
                value = widget.get().strip()
                if key in {'order_notional_usd', 'ai_confidence_threshold'}:
                    existing[key] = float(value or 0)
                else:
                    existing[key] = value
            elif isinstance(widget, ctk.CTkOptionMenu):
                existing[key] = widget.get()
            elif isinstance(widget, ctk.CTkSwitch):
                existing[key] = bool(widget.get())
        self.config_path.write_text(yaml.safe_dump(existing, allow_unicode=True, sort_keys=False), encoding='utf-8')
        self._append_backend(f'Config kaydedildi: {self.config_path}')

    def scan_models(self) -> list[str]:
        models_dir = self.project_root / 'models'
        if not models_dir.exists():
            return ['models/xgboost_trade_model.json']
        json_models = sorted(str(p.relative_to(self.project_root)).replace('\\', '/') for p in models_dir.glob('*.json'))
        ubj_models = sorted(str(p.relative_to(self.project_root)).replace('\\', '/') for p in models_dir.glob('*.ubj'))
        models = json_models + ubj_models
        return models or ['models/xgboost_trade_model.json']

    def refresh_models(self) -> None:
        vals = self.scan_models()
        self.model_combo.configure(values=vals)
        self._append_backend(f'Model listesi yenilendi ({len(vals)} adet).')

    def use_selected_model(self) -> None:
        self.form['ai_model_path'].delete(0, 'end')
        self.form['ai_model_path'].insert(0, self.model_combo.get())
        self._append_backend(f'Seçili model config alanına yazıldı: {self.model_combo.get()}')

    # ---------- processes ----------
    def _creationflags(self) -> int:
        return getattr(subprocess, 'CREATE_NO_WINDOW', 0)

    def start_backend(self) -> None:
        running_health = self._backend_health()
        if running_health and running_health.get('ok'):
            self.backend_process = None
            self._backend_owned = False
            self._append_backend('Backend zaten çalışıyor. Mevcut API sürecine bağlanıldı.')
            return
        if self.backend_process and self.backend_process.poll() is None:
            self._backend_owned = True
            self._append_backend('Backend zaten çalışıyor.')
            return
        self.save_config()
        cmd = [
            sys.executable,
            '-m',
            'tradebot.cli',
            'api',
            '--config',
            str(self.config_path),
            '--host',
            self.api_host,
            '--port',
            str(self.api_port),
        ]
        env = dict(os.environ)
        env['PYTHONUNBUFFERED'] = '1'
        self.backend_process = subprocess.Popen(
            cmd,
            cwd=str(self.project_root),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            creationflags=self._creationflags(),
            env=env,
        )
        self._backend_owned = True
        threading.Thread(target=self._read_process_output, args=(self.backend_process, '[backend]'), daemon=True).start()
        self._append_backend('Backend süreç başlatıldı.')

    def stop_backend(self) -> None:
        if self.backend_process and self.backend_process.poll() is None and self._backend_owned:
            self.backend_process.terminate()
            try:
                self.backend_process.wait(timeout=8)
            except subprocess.TimeoutExpired:
                self.backend_process.kill()
            self._append_backend('Backend süreç durduruldu.')
            self.backend_process = None
            self._backend_owned = False
            return
        running_health = self._backend_health()
        if running_health and running_health.get('ok'):
            self._append_backend("Harici backend algılandı; süreç sahipliği dashboard'da değil, durdurulmadı.")
            return
        self._append_backend('Backend zaten kapalı.')
        self.backend_process = None
        self._backend_owned = False

    def restart_backend(self) -> None:
        if self.backend_process and self.backend_process.poll() is None and self._backend_owned:
            self.stop_backend()
            time.sleep(0.8)
            self.start_backend()
            return
        running_health = self._backend_health()
        if running_health and running_health.get('ok'):
            self._append_backend('Harici backend çalışıyor; yeniden başlatma atlandı, mevcut API sürecine bağlı kalındı.')
            return
        self.stop_backend()
        time.sleep(0.8)
        self.start_backend()

    def start_training(self) -> None:
        symbol = self.train_symbol.get().strip().upper() or 'ETHUSDT'
        out = self.project_root / 'models' / f'{symbol}_model.json'
        cmd = [
            sys.executable,
            '-m',
            'tradebot.cli',
            'train-model',
            '--symbol',
            symbol,
            '--interval',
            '1m',
            '--days',
            '30',
            '--out',
            str(out),
        ]
        self.training_process = subprocess.Popen(
            cmd,
            cwd=str(self.project_root),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            creationflags=self._creationflags(),
            env=dict(os.environ, PYTHONUNBUFFERED='1'),
        )
        threading.Thread(target=self._read_process_output, args=(self.training_process, '[train]'), daemon=True).start()
        self._append_backend(f'Eğitim başlatıldı: {symbol}')

    def _read_process_output(self, process: subprocess.Popen[str], prefix: str) -> None:
        if not process.stdout:
            return
        for line in iter(process.stdout.readline, ''):
            if not line:
                break
            self._backend_queue.put(f'{prefix} {line.rstrip()}')
        process.stdout.close()

    # ---------- API ----------
    def api_get(self, path: str, *, timeout: float = 2.5) -> Any:
        resp = requests.get(f'{self.api_base}{path}', timeout=timeout)
        resp.raise_for_status()
        return resp.json()

    def api_post(self, path: str) -> None:
        try:
            timeout = 15 if path == '/stop' else 5
            resp = requests.post(f'{self.api_base}{path}', timeout=timeout)
            resp.raise_for_status()
            self._append_backend(f'API OK {path}: {resp.json()}')
        except Exception as exc:
            self._append_backend(f'API FAIL {path}: {exc}')

    # ---------- polling/render ----------
    def _poll(self) -> None:
        self._flush_backend_queue()
        self._poll_health_and_status()
        self.after(self.POLL_MS, self._poll)

    def _flush_backend_queue(self) -> None:
        while True:
            try:
                line = self._backend_queue.get_nowait()
            except queue.Empty:
                break
            self._append_backend(line)

    def _poll_health_and_status(self) -> None:
        try:
            health = self.api_get('/health', timeout=1.0)
        except Exception as exc:
            self._last_connected = False
            DashboardApp._set_offline_ui(self, str(exc))
            return

        self._last_connected = bool(health.get('ok'))
        if hasattr(self, 'lbl_connection'):
            self.lbl_connection.configure(text='Backend: ONLINE', text_color=('green', 'light green'))
        if hasattr(self, 'lbl_symbol'):
            self.lbl_symbol.configure(text=f"Sembol: {health.get('symbol', '-')}")

        try:
            status = self.api_get('/status', timeout=2.0)
        except Exception as exc:
            self._append_backend(f'STATUS degrade: {exc}')
            if hasattr(self, 'lbl_ws'):
                self.lbl_ws.configure(text='WS: DEGRADED')
            self._render_health_only(health, str(exc))
            return

        self._last_status = status
        self._render_status(status)
        self._refresh_logs()
        self._chart_poll_counter += 1
        if self._active_page == 'chart' and self._chart_poll_counter % self.CHART_REFRESH_EVERY == 0:
            self.refresh_chart()


