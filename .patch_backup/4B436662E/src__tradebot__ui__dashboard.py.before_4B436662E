def format_ts(ts: int | float | None) -> str:
    if not ts:
        return '-'
    return datetime.fromtimestamp(float(ts) / 1000).strftime('%d.%m.%Y %H:%M:%S')


def format_log_line(item: dict[str, Any]) -> str:
    data = item.get('data') or {}
    return (
        f"{format_ts(item.get('ts'))} | "
        f"{item.get('level', 'INFO'):<5} | "
        f"{item.get('code', '-'):<22} | "
        f"{item.get('message', '-')} | {data}"
    )


def filter_logs(
    logs: list[dict[str, Any]],
    *,
    search: str = '',
    symbol_filter: str = '',
    code_filter: str = '',
) -> list[dict[str, Any]]:
    search_q = search.strip().lower()
    symbol_q = symbol_filter.strip().upper()
    code_q = code_filter.strip().upper()
    out: list[dict[str, Any]] = []
    for item in logs:
        data = item.get('data') or {}
        joined = ' '.join(
            [
                str(item.get('message', '')),
                str(item.get('code', '')),
                str(item.get('level', '')),
                str(data),
            ]
        ).lower()
        code = str(item.get('code', '')).upper()
        symbol = str(data.get('symbol') or data.get('baseAsset') or '')
        if code_q and code_q not in code:
            continue
        if symbol_q and symbol_q not in symbol.upper() and symbol_q not in joined.upper():
            continue
        if search_q and search_q not in joined:
            continue
        out.append(item)
    return out


def extract_signal_markers(logs: list[dict[str, Any]], candles: list[dict[str, Any]]) -> dict[str, list[tuple[int, float]]]:
    if not candles:
        return {'BUY': [], 'SELL': [], 'HOLD': []}
    close_times = [int(c.get('close_time') or c.get('closeTime') or 0) for c in candles]
    prices = [float(c.get('close') or 0.0) for c in candles]
    markers: dict[str, list[tuple[int, float]]] = {'BUY': [], 'SELL': [], 'HOLD': []}
    for item in logs:
        code = str(item.get('code', '')).upper()
        data = item.get('data') or {}
        signal = ''
        if code == 'STRATEGY_EVAL':
            signal = str(data.get('signal', '')).upper()
        elif code == 'AUTO_SIGNAL_EFFECTIVE':
            signal = str(data.get('effectiveSignal', '')).upper()
        elif code == 'ORDER_FILLED':
            signal = str(data.get('side', '')).upper()
        if signal not in markers:
            continue
        ts = int(item.get('ts') or 0)
        if ts <= 0:
            continue
        best_idx = min(range(len(close_times)), key=lambda idx: abs(close_times[idx] - ts))
        markers[signal].append((best_idx, prices[best_idx]))
    return markers




def _fmt_quality_pct(value: Any) -> str:
    try:
        if value is None:
            return '-'
        return f'{float(value):.1f}%'
    except Exception:
        return str(value)


def build_model_quality_text(status: dict[str, Any] | None) -> str:
    status = status or {}
    snapshot = status.get('model_quality_snapshot') or {}
    if not snapshot:
        return '\n'.join([
            'Model Quality',
            '-------------',
            'Samples         : -',
            'Severity        : -',
            'Recommendation  : -',
        ])
    dist = snapshot.get('prediction_distribution_pct') or {}
    conf = snapshot.get('confidence') or {}
    calibration = snapshot.get('calibration') or {}
    gate = status.get('model_quality_gate_snapshot') or {}
    flags = ', '.join(snapshot.get('reason_codes') or []) or '-'
    gate_reasons = ', '.join(gate.get('reason_codes') or gate.get('warnings') or []) or '-'
    return '\n'.join([
        'Model Quality',
        '-------------',
        f'Samples         : {snapshot.get("sample_count", 0)} / {snapshot.get("window_size", "-")}',
        f'Severity        : {snapshot.get("severity", "-")}',
        f'Recommendation  : {snapshot.get("recommendation", "-")}',
        f'Gate decision   : {gate.get("decision", "-")} / demo {_fmt_bool_flag(gate.get("live_demo_allowed", False))} / real {_fmt_bool_flag(gate.get("live_real_allowed", False))}',
        f'Gate reasons    : {gate_reasons}',
        f'BUY/SELL/HOLD   : {_fmt_quality_pct(dist.get("BUY"))} / {_fmt_quality_pct(dist.get("SELL"))} / {_fmt_quality_pct(dist.get("HOLD"))}',
        f'Avg confidence  : {conf.get("avg", "-")}',
        f'Low margin rej. : {_fmt_quality_pct(calibration.get("reject_low_margin_pct"))}',
        f'Flags           : {flags}',
        f'Model age       : {snapshot.get("model_age_days", "-")}',
    ])




def _fmt_bool_flag(value: Any) -> str:
    return 'YES' if bool(value) else 'NO'


def _fmt_reason_codes(value: Any) -> str:
    if not value:
        return '-'
    if isinstance(value, (list, tuple, set)):
        return ', '.join(str(item) for item in value) or '-'
    return str(value)


def build_operator_cockpit_text(status: dict[str, Any] | None) -> str:
    status = status or {}
    diagnostics = status.get('diagnostics_snapshot') or {}
    config = status.get('config_safety_snapshot') or {}
    decision = status.get('decision_audit_snapshot') or {}
    reconciliation = status.get('reconciliation_snapshot') or {}
    performance = status.get('performance_snapshot') or {}
    model_quality = status.get('model_quality_snapshot') or {}
    model_quality_gate = status.get('model_quality_gate_snapshot') or {}
    position = status.get('position_snapshot') or {}
    pending = status.get('pending_snapshot') or {}
    risk = status.get('risk_snapshot') or {}

    effective = decision.get('effective_decision') or {}
    guard = decision.get('guard_path') or {}
    perf_profit_factor = performance.get('profit_factor')
    perf_profit_factor_text = '-' if perf_profit_factor is None else perf_profit_factor
    open_trade = performance.get('open_trade') or {}
    latest_events = diagnostics.get('latest_critical_events') or []

    return '\n'.join([
        'Operator Cockpit',
        '----------------',
        f'Contract        : {status.get("contract_version", "-")}',
        f'Runtime         : {status.get("state", "-")} / WS {status.get("ws_status", "-")}',
        f'Diagnostics     : {diagnostics.get("severity", "-")} / ready {_fmt_bool_flag(diagnostics.get("ready_to_operate", False))}',
        f'Config safety   : {config.get("severity", "-")} / trade {_fmt_bool_flag(config.get("safe_to_trade", False))} / auto {_fmt_bool_flag(config.get("safe_to_auto_trade", False))}',
        f'Decision        : {effective.get("signal", "-")} / {decision.get("action_intent", decision.get("action", "-"))} / submit {_fmt_bool_flag(decision.get("should_submit_order", False))}',
        f'Decision reason : {effective.get("reason", "-")}',
        f'Guard path      : {guard.get("action", decision.get("action", "-"))} / {guard.get("skip_code", decision.get("skip_code", "-")) or "-"}',
        f'Reconciliation  : {reconciliation.get("state", "-")} / {reconciliation.get("recommended_action", "-")}',
        f'Position        : present {_fmt_bool_flag(position.get("present", False))} / qty {position.get("qty", "-")}',
        f'Pending         : present {_fmt_bool_flag(pending.get("present", False))} / {pending.get("side", "-") or "-"} / {pending.get("status", "-") or "-"}',
        f'Risk            : safe_mode {risk.get("safe_mode", False)} / kill {risk.get("kill_switch_active", False)}',
        f'Model quality   : {model_quality.get("severity", "-")} / samples {model_quality.get("sample_count", 0)} / {model_quality.get("recommendation", "-")}',
        f'Model gate      : {model_quality_gate.get("decision", "-")} / demo {_fmt_bool_flag(model_quality_gate.get("live_demo_allowed", False))}',
        f'Performance     : closed {performance.get("closed_trade_count", 0)} / pnl {performance.get("realized_pnl", 0.0)} / win {performance.get("win_rate_pct", 0.0)}% / pf {perf_profit_factor_text}',
        f'Open trade      : {_fmt_bool_flag(open_trade.get("present", False))}',
        f'Critical events : {len(latest_events)}',
        f'Reason codes    : {_fmt_reason_codes(diagnostics.get("reason_codes") or decision.get("reason_codes") or reconciliation.get("reason_codes") or config.get("reason_codes"))}',
    ])

def safe_obj_getattr(obj: object, name: str, default: Any = None) -> Any:
    try:
        return object.__getattribute__(obj, name)
    except Exception:
        return default


