def _utc_stamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def _contract(module_name: str, symbol: str, callable_required: bool) -> dict[str, Any]:
    item: dict[str, Any] = {"module": module_name, "symbol": symbol, "callable_required": callable_required}
    try:
        module = importlib.import_module(module_name)
        value = getattr(module, symbol)
        item.update({"module_imported": True, "module_error": None, "symbol_present": True, "symbol_type": type(value).__name__, "callable_ok": callable(value) if callable_required else True, "restored_by_patch": True})
    except Exception as exc:
        item.update({"module_imported": False, "module_error": f"{type(exc).__name__}: {exc}", "symbol_present": False, "symbol_type": None, "callable_ok": False, "restored_by_patch": False})
    item["contract_ready"] = bool(item["symbol_present"] and item["callable_ok"])
    return item


def build_phase61_h7_report(project_root: str | Path | None = None) -> dict[str, Any]:
    root = Path(project_root or ".").resolve()
    contracts = [_contract("tradebot.production_hardening", sym, callable_req) for sym, callable_req in PRODUCTION_CONTRACTS]
    failures = [item for item in contracts if not item["contract_ready"]]
    snapshot: dict[str, Any] | None = None
    lock_snapshot: dict[str, Any] | None = None
    runtime_lock_handle_ok = False
    production_hardening_snapshot_ok = False
    production_hardening_module_file = None
    production_hardening_module_path = None
    production_hardening_module_error = None
    try:
        module = importlib.import_module("tradebot.production_hardening")
        production_hardening_module_file = getattr(module, "__file__", None)
        production_hardening_module_path = [str(p) for p in getattr(module, "__path__", [])]
        RuntimeLockHandle = getattr(module, "RuntimeLockHandle")
        build_snapshot = getattr(module, "build_production_hardening_snapshot")
        acquire_lock = getattr(module, "acquire_runtime_lock")
        release_lock = getattr(module, "release_runtime_lock")
        snapshot = build_snapshot(project_root=root)
        handle = acquire_lock(project_root=root)
        runtime_lock_handle_ok = isinstance(handle, RuntimeLockHandle) and callable(getattr(handle, "release", None))
        released = release_lock(handle)
        lock_snapshot = released.to_dict() if hasattr(released, "to_dict") else dict(released)
        production_hardening_snapshot_ok = bool(
            isinstance(snapshot, dict)
            and snapshot.get("ok") is True
            and snapshot.get("production_hardening_signature_compatibility_v2") is True
            and snapshot.get("production_hardening_signature_compatibility_h3") is True
            and snapshot.get("production_hardening_signature_compatibility_h4") is True
            and snapshot.get("production_hardening_signature_compatibility_h5") is True
