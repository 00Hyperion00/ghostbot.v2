    gates = _mapping(payload.get("gate_block_counter"))
    lines = [
        "# 4B.4.3.6.6.28G-H3 HYP-006 Runtime Candidate Scan Hook",
        "",
        f"- contract_version: `{payload.get('contract_version')}`",
        f"- branch_id: `{payload.get('branch_id')}`",
