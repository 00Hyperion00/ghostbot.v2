def build_registration_script(
    *,
    project_root: str | os.PathLike[str],
    approval_json: str | os.PathLike[str],
    reports_dir: str | os.PathLike[str],
    symbols: Sequence[str],
    interval: str = "4h",
    days: int = 30,
    task_name: str = PROPOSED_SCHEDULER_TASK_NAME,
) -> str:
    symbol_arg = ",".join(symbol.upper().strip() for symbol in symbols if symbol.strip())
    root = str(Path(project_root))
    approval = str(Path(approval_json))
    reports = str(Path(reports_dir))
    return "\n".join(
        [
            "# 4B.4.3.6.6.28D HYP-006-R1 canonical no-order shadow scheduler registration script",
            "# This script is emitted for operator review. The 28D Python patch does not execute it automatically.",
            "$ErrorActionPreference = 'Stop'",
            f"$ProjectRoot = {json.dumps(root)}",
            f"$ApprovalJson = {json.dumps(approval)}",
            f"$ReportsDir = {json.dumps(reports)}",
            f"$TaskName = {json.dumps(task_name)}",
            "Set-Location $ProjectRoot",
            "$Python = 'python'",
            "$ActionArgs = @(\"tools/run_4B436628D_hyp006_canonical_shadow_cycle.py\",",
            "  \"--registration-approval-json\", $ApprovalJson,",
            f"  \"--symbols\", {json.dumps(symbol_arg)},",
            f"  \"--interval\", {json.dumps(interval)},",
            f"  \"--days\", {int(days)},",
            "  \"--out-dir\", $ReportsDir,",
            "  \"--review-ok\") -join ' '",
            "$Action = New-ScheduledTaskAction -Execute $Python -Argument $ActionArgs -WorkingDirectory $ProjectRoot",
            "$Trigger = New-ScheduledTaskTrigger -Daily -At 00:05",
            "$Settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -ExecutionTimeLimit (New-TimeSpan -Minutes 20)",
            "# Operator action: uncomment the next line only after reviewing the 28D approval report.",
            "# Register-ScheduledTask -TaskName $TaskName -Action $Action -Trigger $Trigger -Settings $Settings -Description 'HYP-006-R1 canonical no-order shadow collection. No paper/live/order actions.' -Force",
            "Write-Host 'Registration script generated. Scheduler task not created until Register-ScheduledTask line is explicitly enabled by operator.'",
            "",
        ]
    )


def build_registration_approval_report(
    *,
    dry_run_report: Mapping[str, Any] | None,
    operator_approval: bool,
    source_paths: Mapping[str, Any] | None = None,
    reports_dir: str | os.PathLike[str] = "reports/hyp006_r1_canonical",
    symbols: Sequence[str] | None = None,
    max_runtime_reports_retained: int = 100,
) -> dict[str, Any]:
    dry_run_ok, dry_run_reasons = validate_28c_dry_run_report(dry_run_report)
    source_paths = dict(source_paths or {})
    symbols = list(symbols or _sequence(_mapping(dry_run_report).get("symbols_requested")))
    retention_policy = build_runtime_artifact_retention_policy(
        reports_dir=reports_dir,
        max_runtime_reports_retained=max_runtime_reports_retained,
    )
    approval_ready = bool(dry_run_ok and operator_approval)
    blockers: list[str] = []
    blockers.extend(dry_run_reasons)
    if not operator_approval:
        blockers.append("NO_OPERATOR_REGISTRATION_APPROVAL")
    if approval_ready:
        blockers.extend(
            [
                "SCHEDULER_SCRIPT_EMITTED_NOT_EXECUTED_BY_PATCH",
                "NO_28E_SCHEDULER_EXECUTION_HEALTH_VERIFY",
                "NO_PAPER_LIVE_TRAINING_RELOAD_ORDER_ENABLEMENT",
            ]
        )
    return {
        "contract_version": CONTRACT_VERSION,
        "report_type": "hyp006_r1_canonical_no_order_shadow_collection_scheduler_registration_operator_approval_pack",
        "decision": "HYP006_R1_CANONICAL_NO_ORDER_SHADOW_REGISTRATION_APPROVED" if approval_ready else "HYP006_R1_CANONICAL_NO_ORDER_SHADOW_REGISTRATION_BLOCKED",
        "ok": approval_ready,
        "generated_at_utc": utc_now_iso(),
        "source_dry_run_contract_version": _mapping(dry_run_report).get("contract_version"),
        "source_dry_run_decision": _mapping(dry_run_report).get("decision"),
        "hypothesis_id": HYPOTHESIS_ID,
        "branch_id": BRANCH_ID,
        "branch_name": BRANCH_NAME,
        "strategy_family": STRATEGY_FAMILY,
        "source_paths": source_paths,
        "dry_run_validation": {"ok": dry_run_ok, "reasons": dry_run_reasons},
        "dry_run_summary": _mapping(_mapping(dry_run_report).get("dry_run_summary")),
        "runtime_artifact_retention_policy": retention_policy,
        "scheduler_registration_approval": {
            "operator_approval_recorded": bool(operator_approval),
            "approval_status": "APPROVED_FOR_SCRIPTED_REGISTRATION_REVIEW" if approval_ready else "BLOCKED",
            "proposed_task_name": PROPOSED_SCHEDULER_TASK_NAME,
            "proposed_reports_dir": str(Path(reports_dir)),
            "requires_28e_scheduler_health_verify": True,
            "scheduler_script_emitted": approval_ready,
            "scheduler_task_created": False,
            "scheduler_task_modified": False,
            "scheduler_mutation_performed": False,
        },
        "symbols_requested": [str(item).upper() for item in symbols],
        "blockers": sorted(set(blockers)),
        "reason_codes": [
            "CANONICAL_NO_ORDER_SHADOW_REGISTRATION_OPERATOR_APPROVAL_GATE",
            "SCHEDULER_REGISTRATION_SCRIPT_ONLY_NOT_EXECUTED_BY_PATCH",
            "RUNTIME_ARTIFACT_RETENTION_POLICY_DECLARED",
            "PAPER_LIVE_GATES_REMAIN_CLOSED",
            "NO_TRAINING_RELOAD_ORDER_ENABLEMENT",
        ],
        "risk_items": [
            {"level": "critical", "code": "NO_ORDER_ONLY_NOT_EXECUTION_EDGE", "detail": "28D authorizes only no-order shadow collection mechanics."},
            {"level": "warning", "code": "SCHEDULER_HEALTH_NOT_VERIFIED", "detail": NEXT_REQUIRED_GATE},
            {"level": "warning", "code": "SHORT_SIDE_COSTS_STILL_UNMODELED", "detail": "Funding, borrow, liquidation, and execution costs remain outside acceptance."},
        ],
