def validate_registration_approval_report(report: Mapping[str, Any] | None) -> tuple[bool, list[str]]:
    payload = _mapping(report)
    reasons: list[str] = []
    if payload.get("contract_version") != CONTRACT_VERSION:
        reasons.append("APPROVAL_CONTRACT_VERSION_MISMATCH")
    if payload.get("decision") != "HYP006_R1_CANONICAL_NO_ORDER_SHADOW_REGISTRATION_APPROVED":
        reasons.append("APPROVAL_DECISION_NOT_APPROVED")
    if payload.get("approved_for_canonical_no_order_shadow_registration") is not True:
        reasons.append("CANONICAL_SHADOW_REGISTRATION_NOT_APPROVED")
    if payload.get("approved_for_shadow_collection") is not True:
        reasons.append("SHADOW_COLLECTION_NOT_APPROVED_FOR_NO_ORDER_REGISTRATION")
    for unsafe_flag in ("approved_for_paper_candidate", "approved_for_live_real", "approved_for_training_candidate"):
        if payload.get(unsafe_flag) is not False:
            reasons.append(f"UNSAFE_APPROVAL_{unsafe_flag.upper()}")
    for mutation_flag in (
        "config_mutation_performed",
        "scheduler_mutation_performed",
        "scheduler_task_created",
        "scheduler_task_modified",
        "trading_action_performed",
        "training_performed",
        "reload_performed",
        "order_actions_performed",
    ):
        if payload.get(mutation_flag) is not False:
            reasons.append(f"UNSAFE_MUTATION_{mutation_flag.upper()}")
    return not reasons, reasons


def load_candles_for_symbols(
    *,
    symbols: Sequence[str],
    interval: str,
    days: int,
    input_csv: str | os.PathLike[str] | None = None,
    base_url: str = PUBLIC_BINANCE_BASE_URL,
) -> tuple[list[Candle], bool, dict[str, int]]:
    network = False
    if input_csv:
        candles = parse_csv_rows(input_csv)
    else:
        candles = []
        network = True
        for symbol in symbols:
            candles.extend(fetch_public_klines(symbol=symbol.upper(), interval=interval, days=days, base_url=base_url))
    grouped = group_by_symbol(candles)
    rows_by_symbol = {symbol: len(grouped.get(symbol.upper(), [])) for symbol in symbols}
    return candles, network, rows_by_symbol


def build_canonical_shadow_cycle_report(
    *,
    registration_approval_report: Mapping[str, Any] | None,
    candidate_spec_source: Mapping[str, Any] | None,
    candles: Sequence[Candle],
    existing_ledger_rows: Sequence[Mapping[str, Any]] | None = None,
    source_paths: Mapping[str, Any] | None = None,
    rows_by_symbol: Mapping[str, int] | None = None,
    network_request_performed: bool = False,
) -> dict[str, Any]:
    approval_ok, approval_reasons = validate_registration_approval_report(registration_approval_report)
    spec_ok, spec_reasons, spec = validate_candidate_spec_source(candidate_spec_source)
    runtime_spec = runtime_spec_from_candidate_spec(candidate_spec_source)
    existing_ids = {str(row.get("observation_id")) for row in (existing_ledger_rows or []) if row.get("observation_id")}
    observations = []
    scan_diagnostics: list[Mapping[str, Any]] = []
    if approval_ok and spec_ok:
        for _, symbol_candles in group_by_symbol(candles).items():
            symbol_observations, symbol_diagnostics = scan_hyp006_short_probe_observations_with_diagnostics(
                symbol_candles,
                runtime_spec=runtime_spec,
                existing_ids=existing_ids,
            )
            observations.extend(symbol_observations)
            scan_diagnostics.append(symbol_diagnostics)
    candidate_scan_diagnostics = merge_candidate_scan_diagnostics(scan_diagnostics)
    rows = []
    for item in observations:
        row = asdict(item)
        row["contract_version"] = CONTRACT_VERSION
        row["operator_review_status"] = "OPERATOR_APPROVED_NO_ORDER_SHADOW_COLLECTION"
        row["canonical_shadow_collection_only"] = True
        rows.append(row)
    summary = summarize_observations(observations) if observations else {
        "dry_run_observation_count": 0,
        "new_unique_dry_run_observation_count": 0,
        "duplicate_existing_observation_count": 0,
        "matured_count": 0,
        "symbols_observed": [],
        "symbols_observed_count": 0,
        "win_count": 0,
        "loss_count": 0,
        "win_rate_pct": 0.0,
        "net_return_bps": 0.0,
        "mean_return_bps": None,
        "median_return_bps": None,
        "profit_factor": 0.0,
        "best_return_bps": None,
        "worst_return_bps": None,
        "sample_observation_ids": [],
    }
    canonical_summary = {
        "shadow_observation_count": summary.get("dry_run_observation_count", 0),
        "new_unique_shadow_observation_count": summary.get("new_unique_dry_run_observation_count", 0),
        "duplicate_existing_observation_count": summary.get("duplicate_existing_observation_count", 0),
        "matured_count": summary.get("matured_count", 0),
        "symbols_observed": summary.get("symbols_observed", []),
        "symbols_observed_count": summary.get("symbols_observed_count", 0),
        "win_count": summary.get("win_count", 0),
        "loss_count": summary.get("loss_count", 0),
        "win_rate_pct": summary.get("win_rate_pct", 0.0),
        "net_return_bps": summary.get("net_return_bps", 0.0),
        "mean_return_bps": summary.get("mean_return_bps"),
        "median_return_bps": summary.get("median_return_bps"),
        "profit_factor": summary.get("profit_factor", 0.0),
        "best_return_bps": summary.get("best_return_bps"),
        "worst_return_bps": summary.get("worst_return_bps"),
        "sample_observation_ids": summary.get("sample_observation_ids", []),
    }
    ok = bool(approval_ok and spec_ok)
    return {
        "contract_version": CONTRACT_VERSION,
        "report_type": "hyp006_r1_canonical_no_order_shadow_collection_cycle_report",
        "decision": "HYP006_R1_CANONICAL_NO_ORDER_SHADOW_COLLECTION_CYCLE_READY" if ok else "HYP006_R1_CANONICAL_NO_ORDER_SHADOW_COLLECTION_CYCLE_BLOCKED",
        "ok": ok,
        "generated_at_utc": utc_now_iso(),
        "hypothesis_id": HYPOTHESIS_ID,
        "branch_id": BRANCH_ID,
        "branch_name": BRANCH_NAME,
        "strategy_family": STRATEGY_FAMILY,
        "approval_validation": {"ok": approval_ok, "reasons": approval_reasons},
        "candidate_spec_validation": {"ok": spec_ok, "reasons": spec_reasons},
        "runtime_spec": {
            "lookback_bars": runtime_spec.lookback_bars,
            "hold_bars": runtime_spec.hold_bars,
            "min_sweep_bps": runtime_spec.min_sweep_bps,
            "min_wick_pct_reference": runtime_spec.min_wick_pct_reference,
            "compression_window": runtime_spec.compression_window,
            "compression_baseline_bars": runtime_spec.compression_baseline_bars,
            "max_compression_ratio_reference": runtime_spec.max_compression_ratio_reference,
            "max_slippage_proxy_bps": runtime_spec.max_slippage_proxy_bps,
            "timeframe": runtime_spec.timeframe,
        },
        "runtime_candidate_scan_hook_contract_version": CANDIDATE_SCAN_HOOK_CONTRACT_VERSION,
        "candidate_scan_diagnostics": candidate_scan_diagnostics,
        "shadow_observations": rows,
        "shadow_summary": canonical_summary,
        "rows_by_symbol": dict(rows_by_symbol or {}),
        "source_paths": dict(source_paths or {}),
        "read_only": True,
        "canonical_no_order_shadow_collection_cycle": True,
        "post_requests_allowed": False,
        "network_request_performed": bool(network_request_performed),
        "config_mutation_performed": False,
        "scheduler_mutation_performed": False,
        "scheduler_task_created": False,
        "scheduler_task_modified": False,
        "branch_state_mutation_performed": False,
        "strategy_parameter_mutation_performed": False,
        "training_performed": False,
        "reload_performed": False,
        "trading_action_performed": False,
        "order_actions_performed": False,
        "approved_for_shadow_collection": True if ok else False,
        "approved_for_training_candidate": False,
        "approved_for_paper_candidate": False,
        "approved_for_live_real": False,
        "paper_transition_candidate_found": False,
        "next_required_gate": NEXT_REQUIRED_GATE,
        "warnings": ["CANONICAL_SHADOW_COLLECTION_IS_NO_ORDER_ONLY"],
    }


def write_markdown(path: str | os.PathLike[str], payload: Mapping[str, Any]) -> None:
    lines = [
        "# 4B.4.3.6.6.28D HYP-006-R1 Canonical No-Order Shadow Registration",
        "",
        f"- decision: `{payload.get('decision')}`",
        f"- branch_id: `{payload.get('branch_id')}`",
        f"- approved_for_shadow_collection: `{payload.get('approved_for_shadow_collection')}`",
        f"- scheduler_mutation_performed: `{payload.get('scheduler_mutation_performed')}`",
        f"- approved_for_paper_candidate: `{payload.get('approved_for_paper_candidate')}`",
        f"- approved_for_live_real: `{payload.get('approved_for_live_real')}`",
        f"- next_required_gate: `{payload.get('next_required_gate')}`",
        f"- candidate_count: `{_mapping(payload.get('candidate_scan_diagnostics')).get('candidate_count')}`",
        f"- near_miss_count: `{_mapping(payload.get('candidate_scan_diagnostics')).get('near_miss_count')}`",
        f"- trigger_count: `{_mapping(payload.get('candidate_scan_diagnostics')).get('trigger_count')}`",
        "",
        "## Recommendation",
        "",
        str(payload.get("recommendation", "")),
    ]
    resolved = Path(path).resolve()
    resolved.parent.mkdir(parents=True, exist_ok=True)
    resolved.write_text("\n".join(lines) + "\n", encoding="utf-8")


def write_registration_bundle(
    payload: Mapping[str, Any],
    out_dir: str | os.PathLike[str],
    *,
    project_root: str | os.PathLike[str],
    symbols: Sequence[str],
    interval: str,
    days: int,
    emit_registration_script: bool = True,
) -> tuple[Path, Path, Path, Path | None]:
    target_dir = Path(out_dir)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    report_json = target_dir / f"{REPORT_PREFIX}_{stamp}.json"
    retention_json = target_dir / f"{RETENTION_POLICY_PREFIX}_{stamp}.json"
    report_md = target_dir / f"{REPORT_PREFIX}_{stamp}.md"
    script_path: Path | None = None
    write_json_atomic(report_json, payload)
    write_json_atomic(retention_json, payload.get("runtime_artifact_retention_policy", {}))
    write_markdown(report_md, payload)
    if emit_registration_script and payload.get("ok") is True:
