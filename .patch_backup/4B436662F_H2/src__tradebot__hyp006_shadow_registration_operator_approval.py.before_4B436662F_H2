def utc_now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def _mapping(value: Any) -> Mapping[str, Any]:
    return value if isinstance(value, Mapping) else {}


def _sequence(value: Any) -> Sequence[Any]:
    if isinstance(value, Sequence) and not isinstance(value, (str, bytes, bytearray)):
        return value
    return []


def validate_28c_dry_run_report(report: Mapping[str, Any] | None) -> tuple[bool, list[str]]:
    payload = _mapping(report)
    reasons: list[str] = []
    if payload.get("contract_version") != SOURCE_DRY_RUN_CONTRACT_VERSION:
        reasons.append("DRY_RUN_CONTRACT_VERSION_MISMATCH")
    if payload.get("decision") != "HYP006_R1_NO_ORDER_SHADOW_RUNNER_DRY_RUN_READY":
        reasons.append("DRY_RUN_DECISION_NOT_READY")
    if payload.get("hypothesis_id") != HYPOTHESIS_ID:
        reasons.append("HYPOTHESIS_ID_MISMATCH")
    if payload.get("branch_id") != BRANCH_ID:
        reasons.append("BRANCH_ID_MISMATCH")
    if payload.get("branch_name") != BRANCH_NAME:
        reasons.append("BRANCH_NAME_MISMATCH")
    if payload.get("runner_dry_run_ready") is not True:
        reasons.append("RUNNER_DRY_RUN_NOT_READY")
    if payload.get("operator_registration_approval_gate_ready") is not True:
        reasons.append("OPERATOR_REGISTRATION_GATE_NOT_READY")
    if payload.get("canonical_scheduler_registration_preflight_ready") is not True:
        reasons.append("SCHEDULER_PREFLIGHT_NOT_READY")
    if payload.get("approved_for_no_order_shadow_collection_registration_candidate") is not True:
        reasons.append("REGISTRATION_CANDIDATE_NOT_APPROVED")
    if payload.get("approved_for_shadow_collection") is not False:
        reasons.append("SOURCE_SHADOW_COLLECTION_SHOULD_BE_BLOCKED_UNTIL_28D")
    for unsafe_flag in ("approved_for_paper_candidate", "approved_for_live_real", "approved_for_training_candidate"):
        if payload.get(unsafe_flag) is not False:
            reasons.append(f"UNSAFE_SOURCE_{unsafe_flag.upper()}")
    for mutation_flag in (
        "config_mutation_performed",
        "scheduler_mutation_performed",
        "trading_action_performed",
        "training_performed",
        "reload_performed",
        "order_actions_performed",
    ):
        if payload.get(mutation_flag) is not False:
            reasons.append(f"UNSAFE_SOURCE_{mutation_flag.upper()}")
    summary = _mapping(payload.get("dry_run_summary"))
    if int(summary.get("new_unique_dry_run_observation_count") or 0) <= 0:
        reasons.append("NO_NEW_UNIQUE_DRY_RUN_OBSERVATIONS")
    return not reasons, reasons


